<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Discover the Beauty of Ethiopia" data-am="የኢትዮጵያን ውበት ያግኙ">Discover the Beauty of Ethiopia</h2>
        <p data-en="Explore history, mountains and culture." data-am="ታሪክ፣ ተራሮች እና ባህልን ያስሱ">Explore history, mountains and culture.</p>
    </div>
</section>

<section class="places-grid">
<h2 data-en="Top Destinations" data-am="ከፍተኛ መዳረሻዎች">Top Destinations</h2>
<div class="grid-container" id="placesGrid">
    <!-- Places will be loaded here -->
</div>
</section>

<script>
// Load top 10 places for homepage
async function loadPlaces() {
    try {
        const response = await fetch('/api/places');
        const allPlaces = await response.json();
        
        // Get only first 10 places for homepage
        const places = allPlaces.slice(0, 10);
        
        const container = document.getElementById('placesGrid');
        
        if (places.length === 0) {
            container.innerHTML = `
                <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                    <i class="fas fa-map-marked-alt" style="font-size: 4rem; color: #888; margin-bottom: 1rem;"></i>
                    <h3 data-en="No Destinations Available" data-am="መዳረሻዎች ገና የሉም">No Destinations Available</h3>
                    <p data-en="Check back soon for amazing Ethiopian destinations" data-am="ለምክም የሚያምር የኢትዮጵያ መዳረሻዎችን ይመልከቱ">Check back soon for amazing Ethiopian destinations</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = places.map(place => `
            <div class="destination-card">
                ${place.image_url && place.image_url !== '' ? `
                    ${place.image_url.startsWith('http') 
                        ? `<img src="${place.image_url}" alt="${place.name}" class="card-image">`
                        : place.image_url.startsWith('/uploads/') 
                        ? `<img src="${place.image_url}" alt="${place.name}" class="card-image">`
                        : `<img src="/img/${place.image_url}" alt="${place.name}" class="card-image" onerror="this.src='https://picsum.photos/seed/${place.name}/400/300.jpg'">`
                    }
                ` : `
                    <img src="https://picsum.photos/seed/${place.name}/400/300.jpg" alt="${place.name}" class="card-image">
                `}
                <div class="card-content">
                    <h3 data-en="${place.name}" data-am="${place.name_am || place.name}">${place.name}</h3>
                    <p class="card-description" data-en="${place.description ? place.description.substring(0, 120) + '...' : 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am ? place.description_am.substring(0, 120) + '...' : 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description ? place.description.substring(0, 120) + '...' : 'Discover this amazing destination in Ethiopia'}</p>
                </div>
                <div class="card-actions">
                    <button class="card-btn btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                    <a href="/place/${place._id.toString()}" class="card-btn btn-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                    ${place.video_url ? `
                        <button class="card-btn btn-video" onclick="showVideo('${place.video_url}', '${place.name}')">
                            <i class="fas fa-play"></i> <span data-en="Watch Video" data-am="ቪዲዮውን ይመልከቱ">Watch Video</span>
                        </button>
                    ` : ''}
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Error loading places:', error);
        document.getElementById('placesGrid').innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later" data-am="እባኮላ በኋላ ይሞክሉ">Please try again later</p>
            </div>
        `;
    }
}

// Load places when page loads
document.addEventListener('DOMContentLoaded', loadPlaces);
</script>

<!-- Explore More Section -->
<section style="padding: 3rem 2rem; text-align: center; background: linear-gradient(135deg, rgba(0,77,64,0.05), rgba(0,128,128,0.05));">
    <h2 data-en="Discover More Destinations" data-am="ተጨማሪ መዳረሻዎችን ያግኙ" style="color: var(--primary-color); margin-bottom: 1rem;">Discover More Destinations</h2>
    <p data-en="Explore our complete collection of Ethiopian destinations organized by category" data-am="የኢትዮጵያን ሙሉ መዳረሻዎችን በምድብ ይመለከቱ" style="font-size: 1.1rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">Explore our complete collection of Ethiopian destinations organized by category</p>
    <a href="/destinations" class="nav-cta" data-en="View All Destinations" data-am="ሁሉንን መዳረሻዎችን ይመልከቱ" style="display: inline-block; text-decoration: none; padding: 1rem 2.5rem; font-size: 1.1rem;">View All Destinations</a>
</section>

