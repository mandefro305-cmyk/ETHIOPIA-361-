        <p style="margin-bottom: 1rem;">© 2026 Ethiopia 361°</p>
        <div class="footer-social" style="display: flex; justify-content: center; gap: 1rem; margin-bottom: 1rem;">
            <a href="https://www.facebook.com/profile.php?id=61558024743838&mibextid=rS40aB7S9Ucbxw6v" target="_blank" style="color: white; font-size: 1.2rem; transition: transform 0.3s ease;" title="Facebook">
                <i class="fab fa-facebook-f"></i>
            </a>
            <a href="https://x.com/Abebech1447551" target="_blank" style="color: white; font-size: 1.2rem; transition: transform 0.3s ease;" title="X (Twitter)">
                <i class="fab fa-x-twitter"></i>
            </a>
            <a href="https://www.instagram.com/belonayalew?igsh=eW9reWZ1YWgycjF6" target="_blank" style="color: white; font-size: 1.2rem; transition: transform 0.3s ease;" title="Instagram">
                <i class="fab fa-instagram"></i>
            </a>
            <a href="https://t.me/mande11" target="_blank" style="color: white; font-size: 1.2rem; transition: transform 0.3s ease;" title="Telegram">
