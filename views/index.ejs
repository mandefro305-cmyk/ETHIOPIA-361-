<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ethiopia 361°</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="css/ai-chat.css">
</head>

<body>

<header>
<h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>

<div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
        <span></span>
        <span></span>
        <span></span>
    </button>
</div>

<nav class="desktop-nav">
<a href="/" data-en="Home" data-am="ቤት">Home</a>
<a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
<a href="/culture" data-en="Culture" data-am="ባህል">Culture</a>
<a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
<a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
<a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
<a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
<a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<nav class="mobile-nav" id="mobile-nav">
<a href="/" data-en="Home" data-am="ቤት">Home</a>
<a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
<a href="/culture" data-en="Culture" data-am="ባህል">Culture</a>
<a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
<a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
<a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
<a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
<a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<div class="theme-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode"></div>

<select id="language" onchange="changeLanguage()">
<option value="en">English</option>
<option value="am">አማርኛ</option>
</select>

</header>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Discover the Beauty of Ethiopia" data-am="የኢትዮጵያን ውበት ያግኙ">Discover the Beauty of Ethiopia</h2>
        <p data-en="Explore history, mountains and culture." data-am="ታሪክ፣ ተራሮች እና ባህልን ያስሱ">Explore history, mountains and culture.</p>
    </div>
</section>

<section class="places-grid" id="placesGrid">
<h2 data-en="Top Destinations" data-am="ከፍተኛ መዳረሻዎች">Top Destinations</h2>
<div class="grid-container">
    <script>
    // Load top 10 places for homepage
    async function loadPlaces() {
    try {
        const response = await fetch('/api/places');
        const allPlaces = await response.json();
        
        // Get only first 10 places for homepage
        const places = allPlaces.slice(0, 10);
        
        const container = document.getElementById('placesGrid');
        
        if (places.length === 0) {
            container.innerHTML = `
                <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                    <i class="fas fa-map-marked-alt" style="font-size: 4rem; color: #888; margin-bottom: 1rem;"></i>
                    <h3 data-en="No Destinations Available" data-am="መዳረሻዎች ገና የሉም">No Destinations Available</h3>
                    <p data-en="Check back soon for amazing Ethiopian destinations" data-am="ለምክም የሚያምር የኢትዮጵያ መዳረሻዎችን ይመልከቱ">Check back soon for amazing Ethiopian destinations</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = places.map(place => `
            <div class="card">
                ${place.image_url ? `
                    ${place.image_url.startsWith('/uploads/') 
                        ? `<img src="${place.image_url}" alt="${place.name}" class="place-img">`
                        : `<img src="/img/${place.image_url}" alt="${place.name}" class="place-img">`
                    }
                ` : `
                    <div style="height: 200px; background: linear-gradient(45deg, var(--primary-color), var(--secondary-color)); display: flex; align-items: center; justify-content: center; margin: -20px -20px 15px -20px; border-radius: 8px 8px 0 0;">
                        <i class="fas fa-image" style="font-size: 3rem; color: white;"></i>
                    </div>
                `}
                <h3 data-en="${place.name}" data-am="${place.name_am || place.name}">${place.name}</h3>
                <p class="place-description">
                    <span class="short-text" data-en="${place.description ? place.description.substring(0, 150) + '...' : 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am ? place.description_am.substring(0, 150) + '...' : 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description ? place.description.substring(0, 150) + '...' : 'Discover this amazing destination in Ethiopia'}</span>
                    <span class="full-text" style="display: none;" data-en="${place.description || 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am || 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description || 'Discover this amazing destination in Ethiopia'}</span>
                </p>
                <div class="card-actions">
                    <button class="btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                    <a href="/place/${place.id}" class="btn-view-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                    ${place.video_url ? `
                        <button class="btn-read-more" onclick="showVideo('${place.video_url}', '${place.name}')" style="background-color: var(--secondary-color); color: var(--text-dark);">
                            <i class="fas fa-play"></i> <span data-en="Watch Video" data-am="ቪዲዮውን ይመልከቱ">Watch Video</span>
                        </button>
                    ` : ''}
                    ${place.description_pdf ? `
                        <a href="${place.description_pdf}" target="_blank" class="btn-read-more" style="background-color: #e74c3c; color: white; text-decoration: none;">
                            <i class="fas fa-file-pdf"></i> <span data-en="Download PDF" data-am="PDF ያውርዱ">Download PDF</span>
                        </a>
                    ` : ''}
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Error loading places:', error);
        document.getElementById('placesGrid').innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later" data-am="እባኮላ በኋላ ይሞክሉ">Please try again later</p>
            </div>
        `;
    }
}
loadPlaces();
    </script>
</div>
</section>

<!-- Explore More Section -->
<section style="padding: 3rem 2rem; text-align: center; background: linear-gradient(135deg, rgba(0,77,64,0.05), rgba(0,128,128,0.05));">
    <h2 data-en="Discover More Destinations" data-am="ተጨማሪ መዳረሻዎችን ያግኙ" style="color: var(--primary-color); margin-bottom: 1rem;">Discover More Destinations</h2>
    <p data-en="Explore our complete collection of Ethiopian destinations organized by category" data-am="የኢትዮጵያን ሙሉ መዳረሻዎችን በምድብ ይመለከቱ" style="font-size: 1.1rem; margin-bottom: 2rem; max-width: 600px; margin-left: auto; margin-right: auto;">Explore our complete collection of Ethiopian destinations organized by category</p>
    <a href="/destinations" class="nav-cta" data-en="View All Destinations" data-am="ሁሉንን መዳረሻዎችን ይመልከቱ" style="display: inline-block; text-decoration: none; padding: 1rem 2.5rem; font-size: 1.1rem;">View All Destinations</a>
</section>

<footer>
<p> 2026 Ethiopia 361°</p>
</footer>

<script src="js/language.js"></script>
<script src="js/ai-chat.js"></script>
<script>
function toggleMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.querySelector('.mobile-menu-btn');
    
    if (mobileNav.classList.contains('active')) {
        mobileNav.classList.remove('active');
        menuBtn.classList.remove('active');
    } else {
        mobileNav.classList.add('active');
        menuBtn.classList.add('active');
    }
}

function toggleReadMore(button) {
    const card = button.closest('.card');
    const shortText = card.querySelector('.short-text');
    const fullText = card.querySelector('.full-text');
    
    if (fullText.style.display === 'none') {
        // Show full text
        shortText.style.display = 'none';
        fullText.style.display = 'inline';
        button.textContent = button.getAttribute('data-am') === 'ተጨማሪ ያንብቡ' ? 'ቀንል' : 'Show Less';
        button.classList.add('expanded');
    } else {
        // Show short text
        shortText.style.display = 'inline';
        fullText.style.display = 'none';
        button.textContent = button.getAttribute('data-en') === 'Read More' ? 'Read More' : 'ተጨማሪ ያንብቡ';
        button.classList.remove('expanded');
    }
}
</script>

</body>
</html>