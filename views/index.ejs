<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Ethiopia 361°</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="css/ai-chat.css">
</head>

<body>

<header>
<h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>

<div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
        <span></span>
        <span></span>
        <span></span>
    </button>
</div>

<nav class="desktop-nav">
<a href="/">Home</a>
<a href="/destinations">Destinations</a>
<a href="/culture">Culture</a>
<a href="/guide">Travel Guide</a>
<a href="/gallery">Gallery</a>
<a href="/blog">Blog</a>
<a href="/contact">Contact</a>
</nav>

<nav class="mobile-nav" id="mobile-nav">
<a href="/">Home</a>
<a href="/destinations">Destinations</a>
<a href="/culture">Culture</a>
<a href="/guide">Travel Guide</a>
<a href="/gallery">Gallery</a>
<a href="/blog">Blog</a>
<a href="/contact">Contact</a>
</nav>

<select id="language" onchange="changeLanguage()">
<option value="en">English</option>
<option value="am">አማርኛ</option>
</select>

</header>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Discover the Beauty of Ethiopia" data-am="የኢትዮጵያን ውበት ያግኙ">Discover the Beauty of Ethiopia</h2>
        <p data-en="Explore history, mountains and culture." data-am="ታሪክ፣ ተራሮች እና ባህልን ያስሱ">Explore history, mountains and culture.</p>
    </div>
</section>

<section class="places-grid">
<h2 data-en="Top Destinations" data-am="ከፍተኛ መዳረሻዎች">Top Destinations</h2>
<div class="grid-container">
    <% if(locals.places && places.length > 0) { %>
        <% places.forEach(place => { %>
            <div class="card">
                <% if(place.image_url) { %>
                    <% if(place.image_url.startsWith('/uploads/')) { %>
                        <img src="<%= place.image_url %>" alt="<%= place.name %>" class="place-img">
                    <% } else { %>
                        <img src="/img/<%= place.image_url %>" alt="<%= place.name %>" class="place-img">
                    <% } %>
                <% } %>
                <h3 data-en="<%= place.name %>" data-am="<%= place.name_am || place.name %>"><%= place.name %></h3>
                <p class="place-description">
                    <span class="short-text" data-en="<%= place.description ? place.description.substring(0, 100) + '...' : 'Discover this amazing destination in Ethiopia' %>" data-am="<%= place.description_am ? place.description_am.substring(0, 100) + '...' : 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ' %>"><%= place.description ? place.description.substring(0, 100) + '...' : 'Discover this amazing destination in Ethiopia' %></span>
                    <span class="full-text" style="display: none;" data-en="<%= place.description || 'Discover this amazing destination in Ethiopia' %>" data-am="<%= place.description_am || 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ' %>"><%= place.description || 'Discover this amazing destination in Ethiopia' %></span>
                </p>
                <div class="card-actions">
                    <button class="btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                    <a href="/place/<%= place.id %>" class="btn-view-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                </div>
            </div>
        <% }) %>
    <% } else { %>
        <p>No places added yet. Check back soon!</p>
    <% } %>
</div>
</section>

<footer>
<p>© 2026 Ethiopia 361°</p>
</footer>

<script src="js/language.js"></script>
<script src="js/ai-chat.js"></script>
<script>
function toggleMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.querySelector('.mobile-menu-btn');
    
    if (mobileNav.classList.contains('active')) {
        mobileNav.classList.remove('active');
        menuBtn.classList.remove('active');
    } else {
        mobileNav.classList.add('active');
        menuBtn.classList.add('active');
    }
}

function toggleReadMore(button) {
    const card = button.closest('.card');
    const shortText = card.querySelector('.short-text');
    const fullText = card.querySelector('.full-text');
    
    if (fullText.style.display === 'none') {
        // Show full text
        shortText.style.display = 'none';
        fullText.style.display = 'inline';
        button.textContent = button.getAttribute('data-am') === 'ተጨማሪ ያንብቡ' ? 'ቀንል' : 'Show Less';
        button.classList.add('expanded');
    } else {
        // Show short text
        shortText.style.display = 'inline';
        fullText.style.display = 'none';
        button.textContent = button.getAttribute('data-en') === 'Read More' ? 'Read More' : 'ተጨማሪ ያንብቡ';
        button.classList.remove('expanded');
    }
}
</script>

</body>
</html>