<script>
function toggleMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.querySelector('.mobile-menu-btn');
    
    if (mobileNav.classList.contains('active')) {
        mobileNav.classList.remove('active');
        menuBtn.classList.remove('active');
    } else {
        mobileNav.classList.add('active');
        menuBtn.classList.add('active');
    }
}

function toggleReadMore(button) {
    const card = button.closest('.destination-card');
    const description = card.querySelector('.card-description');
    const currentLang = localStorage.getItem('selectedLanguage') || 'en';
    
    if (description) {
        const isExpanded = description.style.maxHeight === 'none';
        
        if (isExpanded) {
            // Collapse
            description.style.maxHeight = '4.8rem';
            description.style.overflow = 'hidden';
            button.setAttribute('data-en', 'Read More');
            button.setAttribute('data-am', 'ተጨማሪ ያንብቡ');
            button.textContent = currentLang === 'am' ? 'ተጨማሪ ያንብቡ' : 'Read More';
        } else {
            // Expand
            const fullText = currentLang === 'am' ? description.getAttribute('data-am') : description.getAttribute('data-en');
            description.textContent = fullText;
            description.style.maxHeight = 'none';
            description.style.overflow = 'visible';
            button.setAttribute('data-en', 'Read Less');
            button.setAttribute('data-am', 'ያነሰ ያንብቡ');
            button.textContent = currentLang === 'am' ? 'ያነሰ ያንብቡ' : 'Read Less';
        }
    }
}

function showVideo(videoUrl, placeName) {
    // Create modal
    const modal = document.createElement('div');
    modal.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
    `;
    
    modal.innerHTML = `
        <div style="background: white; border-radius: 16px; max-width: 800px; width: 90%; max-height: 90vh; position: relative;">
            <div style="padding: 2rem; border-bottom: 1px solid #e0e0e0;">
                <h3 style="margin: 0; color: var(--primary-color);">${placeName}</h3>
                <button onclick="this.closest('.video-modal').remove()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">×</button>
            </div>
            <div style="padding: 2rem; text-align: center;">
                ${videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be') ? 
                    (() => {
                        let videoId = '';
                        let embedUrl = videoUrl;
                        
                        if (videoUrl.includes('watch?v=')) {
                            videoId = videoUrl.split('watch?v=')[1].split('&')[0];
                        } else if (videoUrl.includes('youtu.be/')) {
                            videoId = videoUrl.split('youtu.be/')[1].split('?')[0];
                        }
                        
                        embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}`;
                        
                        return `
                            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px;">
                                <iframe 
                                    src="${embedUrl}" 
                                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 8px;"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                    allowfullscreen
                                    onload="this.style.display='block'; this.nextElementSibling.style.display='none';"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                                </iframe>
                                <div style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; box-sizing: border-box;">
                                    <i class="fas fa-play-circle" style="font-size: 3rem; color: white; margin-bottom: 1rem;"></i>
                                    <h3 style="color: white; margin-bottom: 0.5rem;">Video Available</h3>
                                    <p style="color: white; margin-bottom: 1rem; font-size: 0.9rem;">This video is available on YouTube</p>
                                    <a href="${videoUrl}" target="_blank" style="display: inline-block; background: white; color: #667eea; padding: 0.5rem 1rem; border-radius: 20px; text-decoration: none; font-weight: bold;">
                                        <i class="fab fa-youtube"></i> Watch on YouTube
                                    </a>
                                </div>
                            </div>
                        `;
                    })() :
                    `<video controls style="width: 100%; max-height: 400px; border-radius: 8px;">
                        <source src="${videoUrl}" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>`
                }
            </div>
        </div>
    `;
    
    modal.className = 'video-modal';
    document.body.appendChild(modal);
    
    // Close modal on background click
    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            modal.remove();
        }
    });
}

</script>

