        </button>
    </div>
</header>
<nav class="mobile-nav" id="mobile-nav">
    <a href="/" data-en="Home" data-am="ቤት">Home</a>
    <a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
    <a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
    <a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
    <a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
    <a href="/contact" class="active" data-en="Contact" data-am="ይድረሹ">Contact</a>
    <a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Get in Touch" data-am="ይግኙን">Get in Touch</h2>
        <p data-en="We'd love to hear from you about your Ethiopian travel experience" data-am="ስለ የኢትዮጵያ ጉዞ ተሞክሮዎ እንገኝዎ">We'd love to hear from you about your Ethiopian travel experience</p>
    </div>
</section>

<section class="contact-container" style="padding: 2rem 1rem; max-width: 1200px; margin: 0 auto;">
    <div class="contact-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start;">
        
        <!-- Contact Information -->
        <div class="contact-info">
            <h2 data-en="Contact Information" data-am="የሚገኙበት መረጃዎች" style="color: var(--primary-color); margin-bottom: 2rem;">Contact Information</h2>
            
            <div class="info-card" style="background: white; padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1); margin-bottom: 1.5rem; transition: all 0.3s ease;">
                <div class="info-item" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                    <div class="info-icon" style="width: 45px; height: 45px; background: linear-gradient(135deg, var(--primary-color), #00695c); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.1rem; flex-shrink: 0;">
                        <i class="fas fa-envelope"></i>
                    </div>
                    <div>
                        <h4 data-en="Email" data-am="ኢሜይል" style="margin: 0; color: #333; font-size: 0.95rem;">Email</h4>
                        <p data-en="kademandefro@gmail.com" data-am="kademandefro@gmail.com" style="margin: 0; color: #666; font-size: 0.9rem;">kademandefro@gmail.com</p>
                    </div>
                </div>
                
                <div class="info-item" style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem;">
                    <div class="info-icon" style="width: 45px; height: 45px; background: linear-gradient(135deg, var(--secondary-color), #f39c12); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.1rem; flex-shrink: 0;">
                        <i class="fas fa-phone"></i>
                    </div>
                    <div>
                        <h4 data-en="Phone" data-am="ስልክ" style="margin: 0; color: #333; font-size: 0.95rem;">Phone</h4>
                        <p data-en="+251 9XX XXX XXX" data-am="+251 9XX XXX XXX" style="margin: 0; color: #666; font-size: 0.9rem;">+251 9XX XXX XXX</p>
                    </div>
                </div>
                
                <div class="info-item" style="display: flex; align-items: center; gap: 1rem;">
                    <div class="info-icon" style="width: 45px; height: 45px; background: linear-gradient(135deg, #e74c3c, #c0392b); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 1.1rem; flex-shrink: 0;">
                        <i class="fas fa-map-marker-alt"></i>
                    </div>
                    <div>
                        <h4 data-en="Location" data-am="አካል" style="margin: 0; color: #333; font-size: 0.95rem;">Location</h4>
                        <p data-en="Addis Ababa, Ethiopia" data-am="አዲስ አባባ, ኢትዮጵያ" style="margin: 0; color: #666; font-size: 0.9rem;">Addis Ababa, Ethiopia</p>
                    </div>
                </div>
            </div>
            
            <div class="social-links" style="text-align: center; padding: 1rem;">
                <h3 data-en="Follow Us" data-am="ይከተሉን" style="color: var(--primary-color); margin-bottom: 1rem; font-size: 1.1rem;">Follow Us</h3>
                <div class="social-icons" style="display: flex; justify-content: center; gap: 0.75rem; flex-wrap: wrap;">
                    <a href="https://www.facebook.com/profile.php?id=61558024743838&mibextid=rS40aB7S9Ucbxw6v" target="_blank" class="social-icon" style="width: 45px; height: 45px; background: #1877f2; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease; font-size: 1.2rem;" title="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="https://x.com/Abebech1447551" target="_blank" class="social-icon" style="width: 45px; height: 45px; background: #000000; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease; font-size: 1.2rem;" title="X (Twitter)">
                        <i class="fab fa-x-twitter"></i>
                    </a>
                    <a href="https://www.instagram.com/belonayalew?igsh=eW9reWZ1YWgycjF6" target="_blank" class="social-icon" style="width: 45px; height: 45px; background: linear-gradient(45deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease; font-size: 1.2rem;" title="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="https://t.me/mande11" target="_blank" class="social-icon" style="width: 45px; height: 45px; background: #0088cc; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s ease; font-size: 1.2rem;" title="Telegram">
                        <i class="fab fa-telegram"></i>
                    </a>
                </div>
                <p style="margin-top: 0.75rem; color: #666; font-size: 0.85rem;" data-en="Connect with us on social media" data-am="በሶሻል ሚዲያ ይገናኙን">Connect with us on social media</p>
            </div>
        </div>
        
        <!-- Contact Form -->
        <div class="contact-form-section">
            <h2 data-en="Send us a Message" data-am="መልእክት ይላኩን" style="color: var(--primary-color); margin-bottom: 2rem;">Send us a Message</h2>
            
            <div id="formMessage" style="display: none; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; text-align: center;"></div>
            
            <form id="contactForm" class="modern-contact-form" style="background: white; padding: 1.5rem; border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label data-en="Name" data-am="ስም" style="display: block; margin-bottom: 0.5rem; color: #333; font-weight: 500; font-size: 0.95rem;">Name</label>
                    <input type="text" id="name" name="name" required style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.95rem; transition: all 0.3s ease; box-sizing: border-box;">
                </div>
                
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label data-en="Email" data-am="ኢሜይል" style="display: block; margin-bottom: 0.5rem; color: #333; font-weight: 500; font-size: 0.95rem;">Email</label>
                    <input type="email" id="email" name="email" required style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.95rem; transition: all 0.3s ease; box-sizing: border-box;">
                </div>
                
                <div class="form-group" style="margin-bottom: 1rem;">
                    <label data-en="Message" data-am="መልእክት" style="display: block; margin-bottom: 0.5rem; color: #333; font-weight: 500; font-size: 0.95rem;">Message</label>
                    <textarea id="message" name="message" rows="5" required style="width: 100%; padding: 12px; border: 2px solid #e0e0e0; border-radius: 8px; font-size: 0.95rem; resize: vertical; transition: all 0.3s ease; box-sizing: border-box;"></textarea>
                </div>
                
                <button type="submit" class="submit-btn" style="width: 100%; padding: 12px 24px; background: linear-gradient(135deg, var(--primary-color), #00695c); color: white; border: none; border-radius: 8px; font-size: 1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease;">
                    <i class="fas fa-envelope"></i> <span data-en="Send Message" data-am="መልእክትን ይላኩ">Send Message</span>
                </button>
            </form>
        </div>
    </div>
</section>

<!-- Success Modal -->
<div id="successModal" class="modal" style="display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0,0,0,0.5); align-items: center; justify-content: center;">
    <div class="modal-content" style="background: white; padding: 3rem; border-radius: 16px; max-width: 500px; text-align: center; position: relative;">
        <div class="success-icon" style="width: 80px; height: 80px; background: linear-gradient(135deg, #27ae60, #2ecc71); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 2rem; color: white; font-size: 2rem;">
            <i class="fas fa-check"></i>
        </div>
        <h3 data-en="Message Sent Successfully!" data-am="መልእክት ተልኳኽ!" style="color: var(--primary-color); margin-bottom: 1rem;">Message Sent Successfully!</h3>
        <p data-en="Thank you for contacting us. We'll get back to you soon." data-am="ስለ መግኛችዎ እናመሰግናለን። በቅርበት እንመለስዎታለን።" style="color: #666; margin-bottom: 2rem;">Thank you for contacting us. We'll get back to you soon.</p>
        <button onclick="closeModal()" class="close-modal-btn" style="padding: 1rem 2rem; background: var(--primary-color); color: white; border: none; border-radius: 8px; cursor: pointer;">
            <span data-en="Close" data-am="ዝጋ">Close</span>
        </button>
    </div>
</div>

<script src="/js/language.js"></script>
<script src="/js/ai-chat.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contactForm');
    const formMessage = document.getElementById('formMessage');
    const successModal = document.getElementById('successModal');
    
    form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        var senderName = document.getElementById('name').value.trim();
        var senderEmail = document.getElementById('email').value.trim();
        var senderMessage = document.getElementById('message').value.trim();
        
        if (!senderName || !senderEmail || !senderMessage) return;
        
        var to = 'kademandefro@gmail.com';
        var subject = 'Ethiopia 361° Contact from ' + senderName;
        var body = 'Name: ' + senderName + '\nEmail: ' + senderEmail + '\n\nMessage:\n' + senderMessage;
        
        var mailtoLink = 'mailto:' + encodeURIComponent(to) +
            '?subject=' + encodeURIComponent(subject) +
            '&body=' + encodeURIComponent(body);
        
        window.location.href = mailtoLink;
        
        // Show success modal after a short delay
        setTimeout(function() {
            successModal.style.display = 'flex';
            form.reset();
        }, 500);
    });
    
    // Form field animations
    const inputs = form.querySelectorAll('input, textarea');
    inputs.forEach(input => {
        input.addEventListener('focus', function() {
            this.style.borderColor = 'var(--primary-color)';
            this.style.boxShadow = '0 0 0 3px rgba(0,77,64,0.1)';
        });
        
        input.addEventListener('blur', function() {
            this.style.borderColor = '#e0e0e0';
            this.style.boxShadow = 'none';
        });
    });
    
    // Social icon hover effects
    const socialIcons = document.querySelectorAll('.social-icon');
    socialIcons.forEach(icon => {
        icon.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-3px) scale(1.1)';
        });
        
        icon.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0) scale(1)';
        });
    });
});

function closeModal() {
    document.getElementById('successModal').style.display = 'none';
}

function toggleMobileMenu() {
    const nav = document.getElementById('mobile-nav');
    nav.classList.toggle('active');
}
</script>

<style>
.info-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
}

.info-icon:hover {
    transform: scale(1.1);
}

.social-icon:hover {
    transform: translateY(-3px) scale(1.1);
    box-shadow: 0 10px 20px rgba(0,0,0,0.2);
}

.modern-contact-form input:focus,
.modern-contact-form textarea:focus {
    outline: none;
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(0,77,64,0.1);
}

.submit-btn:hover {
    background: linear-gradient(135deg, #00695c, #004d40);
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0,77,64,0.3);
}

/* Responsive */
@media (max-width: 768px) {
    .contact-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    
    .contact-form-section,
    .contact-info {
        order: 2;
    }
    
    .contact-info {
        order: 1;
    }
}

/* Mobile Styles */
@media (max-width: 768px) {
    .contact-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
    }
    
    .contact-container {
        padding: 1rem 0.5rem !important;
    }
    
    .info-card {
        padding: 1rem !important;
    }
    
    .info-item {
        margin-bottom: 0.75rem !important;
    }
    
    .info-icon {
        width: 40px !important;
        height: 40px !important;
        font-size: 1rem !important;
    }
    
    .social-icons {
        gap: 0.5rem !important;
    }
    
    .social-icon {
        width: 40px !important;
        height: 40px !important;
        font-size: 1.1rem !important;
    }
    
    .modern-contact-form {
        padding: 1rem !important;
    }
    
    .form-group {
        margin-bottom: 0.75rem !important;
    }
    
    .form-group input,
    .form-group textarea {
        padding: 10px !important;
        font-size: 0.9rem !important;
    }
    
    .submit-btn {
        padding: 10px 20px !important;
        font-size: 0.95rem !important;
    }
    
    h2 {
        font-size: 1.3rem !important;
        margin-bottom: 1rem !important;
    }
    
    h3 {
        font-size: 1rem !important;
    }
}
</style>
</body>
</html>