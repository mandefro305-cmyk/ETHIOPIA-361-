<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Place - Ethiopia 361°</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .admin-container {
            max-width: 1000px;
            margin: 50px auto;
            padding: 2rem;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .form-group {
            margin-bottom: 1rem;
        }
        .form-group label {
            display: block;
            margin-bottom: .5rem;
            font-weight: bold;
        }
        .form-group input, .form-group textarea {
            width: 100%;
            padding: .5rem;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        .btn {
            padding: 10px 15px;
            background-color: #004d40;
            color: #fff;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            margin-right: 10px;
        }
        .btn-secondary {
            background-color: #6c757d;
        }
        .btn-danger {
            background-color: #d32f2f;
        }
        .header-flex {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .current-media {
            margin: 10px 0;
            padding: 10px;
            background-color: #f8f9fa;
            border-radius: 4px;
        }
        .current-media img {
            max-width: 200px;
            max-height: 150px;
            object-fit: cover;
            border-radius: 4px;
        }
        .current-media video {
            max-width: 200px;
            max-height: 150px;
            border-radius: 4px;
        }
        
        .image-preview-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }
        
        .image-preview-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            aspect-ratio: 1;
            border: 2px solid #667eea;
        }
        
        .image-preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .image-preview-item .remove-image {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(255, 255, 255, 0.9);
            color: #e74c3c;
            border: none;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            transition: all 0.3s ease;
        }
        
        .image-preview-item .remove-image:hover {
            background: #e74c3c;
            color: white;
            transform: scale(1.1);
        }
        
        .current-gallery {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 10px;
        }
        
        .current-gallery-img {
            width: 100px;
            height: 100px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #ddd;
            position: relative;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .current-gallery-img:hover {
            border-color: #e74c3c;
            transform: scale(1.05);
        }
        
        .delete-image-overlay {
            position: absolute;
            top: 0;
            right: 0;
            background: rgba(231, 76, 60, 0.9);
            color: white;
            border: none;
            border-radius: 0 8px 0 8px;
            width: 25px;
            height: 25px;
            cursor: pointer;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
        }
        
        .current-gallery-item {
            position: relative;
            display: inline-block;
            margin: 5px;
        }
        
        .current-gallery-item:hover .delete-image-overlay {
            display: flex;
        }
    </style>
</head>
<body>
    <div class="admin-container">
        <div class="header-flex">
            <h2>Edit Place</h2>
            <div>
                <a href="/admin" class="btn btn-secondary">Back to Admin</a>
                <a href="/logout" class="btn btn-danger">Logout</a>
            </div>
        </div>
        <hr>

        <form action="/admin/update/<%= place._id %>" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label>Name (English):</label>
                <input type="text" name="name" value="<%= place.name %>" required>
            </div>
            <div class="form-group">
                <label>Name (Amharic):</label>
                <input type="text" name="name_am" value="<%= place.name_am || '' %>">
            </div>
            <div class="form-group">
                <label>Description (English):</label>
                <textarea name="description" rows="4" required><%= place.description %></textarea>
            </div>
            <div class="form-group">
                <label>Description (Amharic):</label>
                <textarea name="description_am" rows="4"><%= place.description_am || '' %></textarea>
            </div>
            
            <div class="form-group">
                <label>Category:</label>
                <select name="category" required>
                    <option value="">Select Category</option>
                    <option value="Historical" <%= place.category === 'Historical' ? 'selected' : '' %>>Historical</option>
                    <option value="Natural" <%= place.category === 'Natural' ? 'selected' : '' %>>Natural</option>
                    <option value="Cultural" <%= place.category === 'Cultural' ? 'selected' : '' %>>Cultural</option>
                    <option value="Religious" <%= place.category === 'Religious' ? 'selected' : '' %>>Religious</option>
                    <option value="Adventure" <%= place.category === 'Adventure' ? 'selected' : '' %>>Adventure</option>
                </select>
            </div>
            
            <!-- Travel Guide Section -->
            <h3>Travel Guide Information</h3>
            <div class="form-group">
                <label>Best Time to Visit:</label>
                <input type="text" name="best_time" value="<%= place.travel_guide ? place.travel_guide.best_time || '' : '' %>">
            </div>
            <div class="form-group">
                <label>How to Get There:</label>
                <textarea name="how_to_get_there" rows="3"><%= place.travel_guide ? place.travel_guide.how_to_get_there || '' : '' %></textarea>
            </div>
            <div class="form-group">
                <label>What to Bring:</label>
                <textarea name="what_to_bring" rows="3"><%= place.travel_guide ? place.travel_guide.what_to_bring || '' : '' %></textarea>
            </div>
            <div class="form-group">
                <label>Accommodation:</label>
                <textarea name="accommodation" rows="3"><%= place.travel_guide ? place.travel_guide.accommodation || '' : '' %></textarea>
            </div>
            <div class="form-group">
                <label>Local Tips:</label>
                <textarea name="local_tips" rows="3"><%= place.travel_guide ? place.travel_guide.local_tips || '' : '' %></textarea>
            </div>
            
            <div class="form-group">
                <label>Main Image:</label>
                <% if(place.image_url) { %>
                    <div class="current-media">
                        <strong>Current Main Image:</strong><br>
                        <% if(place.image_url.startsWith('/uploads/')) { %>
                            <img src="<%= place.image_url %>" alt="<%= place.name %>">
                        <% } else { %>
                            <img src="/img/<%= place.image_url %>" alt="<%= place.name %>">
                        <% } %>
                        <br><small><%= place.image_url %></small>
                    </div>
                <% } %>
                <label>Upload New Main Image:</label>
                <input type="file" name="image" accept="image/*">
                <small>Or enter new Main Image URL:</small>
                <input type="text" name="image_url" placeholder="e.g., lalibela.jpg" value="<%= place.image_url && !place.image_url.startsWith('/uploads/') ? place.image_url : '' %>">
            </div>
            
            <div class="form-group">
                <label>Additional Images (Gallery):</label>
                <input type="file" name="additional_images" accept="image/*" multiple>
                <small>Select up to 5 additional images to add to existing gallery (Max 50MB each) - Total: 6 images including main image</small>
                <div id="image-preview" class="image-preview-container"></div>
                <% if(place.gallery_images) { %>
                    <div class="current-media">
                        <strong>Current Gallery Images (<%= place.gallery_images.length %>/6):</strong><br>
                        <div class="current-gallery">
                            <% 
                            try {
                                const galleryImages = place.gallery_images;
                                galleryImages.forEach((img, index) => { %>
                                    <div class="current-gallery-item">
                                        <% if(img.startsWith('/uploads/')) { %>
                                            <img src="<%= img %>" alt="<%= place.name %> - Image <%= index + 1 %>" class="current-gallery-img" title="Current image <%= index + 1 %>">
                                        <% } else { %>
                                            <img src="/img/<%= img %>" alt="<%= place.name %> - Image <%= index + 1 %>" class="current-gallery-img" title="Current image <%= index + 1 %>">
                                        <% } %>
                                        <button type="button" class="delete-image-overlay" data-image="<%= img %>" data-index="<%= index %>" title="Delete image">×</button>
                                    </div>
                                <% });
                            } catch(e) { %>
                                <p>Error loading gallery images</p>
                            <% } %>
                        </div>
                        <small><em>New images will be added to this gallery (up to 6 total)</em></small>
                    </div>
                <% } else if(place.image_url) { %>
                    <div class="current-media">
                        <strong>Current Images:</strong><br>
                        <div class="current-gallery">
                            <% if(place.image_url.startsWith('/uploads/')) { %>
                                <img src="<%= place.image_url %>" alt="<%= place.name %>" class="current-gallery-img" title="Main image">
                            <% } else { %>
                                <img src="/img/<%= place.image_url %>" alt="<%= place.name %>" class="current-gallery-img" title="Main image">
                            <% } %>
                        </div>
                        <small><em>New images will be added to create a full gallery (up to 6 total)</em></small>
                    </div>
                <% } %>
            </div>
            
            <div class="form-group">
                <label>Video:</label>
                <% if(place.video_url) { %>
                    <div class="current-media">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <strong>Current Video:</strong>
                            <button type="button" class="btn btn-danger" onclick="removeVideo()" style="margin-left: 10px; padding: 5px 10px; font-size: 12px;">
                                <i class="fas fa-trash"></i> Delete Video
                            </button>
                        </div>
                        <br>
                        <% if(place.video_url.startsWith('/uploads/')) { %>
                            <video controls style="max-width: 200px; max-height: 150px; border-radius: 4px;">
                                <source src="<%= place.video_url %>" type="video/mp4">
                            </video>
                        <% } else { %>
                            <iframe src="<%= place.video_url %>" width="200" height="150" frameborder="0" style="border-radius: 4px;"></iframe>
                        <% } %>
                        <br><small><%= place.video_url %></small>
                    </div>
                <% } %>
                <label>Upload New Video:</label>
                <input type="file" name="video" accept="video/*">
                <small>Or enter new Video URL:</small>
                <input type="url" name="video_url" placeholder="e.g., YouTube embed URL" value="<%= place.video_url && !place.video_url.startsWith('/uploads/') ? place.video_url : '' %>">
                <input type="hidden" id="delete-video" name="delete_video" value="">
            </div>
            
            <button type="submit" class="btn">Update Place</button>
            <a href="/admin" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
    
    <script>
    // Wait for DOM to be fully loaded
    document.addEventListener('DOMContentLoaded', function() {
        
        // Video deletion functionality
        function removeVideo() {
            if (confirm('Are you sure you want to remove this video from this place?')) {
                // Hide the current video section
                const currentVideoSection = document.querySelector('.current-media');
                if (currentVideoSection) {
                    currentVideoSection.style.opacity = '0.5';
                    currentVideoSection.style.transform = 'scale(0.9)';
                    
                    // Set the delete video flag
                    const deleteVideoInput = document.getElementById('delete-video') || 
                        (() => {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.id = 'delete-video';
                            input.name = 'delete_video';
                            input.value = 'true';
                            document.querySelector('form').appendChild(input);
                            return input;
                        })();
                    
                    deleteVideoInput.value = 'true';
                    
                    // Hide the video section
                    setTimeout(() => {
                        currentVideoSection.style.display = 'none';
                    }, 300);
                }
            }
        }
        
        // Image deletion functionality
        function removeFromGallery(imagePath, index) {
            if (confirm('Are you sure you want to remove this image from the gallery?')) {
                // Find the gallery item and remove it with animation
                const galleryItems = document.querySelectorAll('.current-gallery-item');
                const targetItem = galleryItems[index];
                
                if (targetItem) {
                    targetItem.style.opacity = '0.5';
                    targetItem.style.transform = 'scale(0.8)';
                    
                    // Add to a hidden input to track deleted images
                    const deletedImagesInput = document.getElementById('deleted-images') || 
                        (() => {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.id = 'deleted-images';
                            input.name = 'deleted_images';
                            document.querySelector('form').appendChild(input);
                            return input;
                        })();
                    
                    let deletedImages = deletedImagesInput.value ? JSON.parse(deletedImagesInput.value) : [];
                    deletedImages.push(imagePath);
                    deletedImagesInput.value = JSON.stringify(deletedImages);
                    
                    // Hide the item
                    setTimeout(() => {
                        targetItem.style.display = 'none';
                        updateGalleryCount();
                    }, 300);
                }
            }
        }
        
        // Update gallery count display
        function updateGalleryCount() {
            const visibleItems = document.querySelectorAll('.current-gallery-item:not([style*="display: none"])');
            const countElement = document.querySelector('strong');
            if (countElement && visibleItems.length >= 0) {
                countElement.innerHTML = `Current Gallery Images (${visibleItems.length}/6):`;
            }
        }
        
        // Add event listeners to delete buttons
        document.querySelectorAll('.delete-image-overlay').forEach(button => {
            button.addEventListener('click', function() {
                const imagePath = this.getAttribute('data-image');
                const index = parseInt(this.getAttribute('data-index'));
                removeFromGallery(imagePath, index);
            });
        });
        
        // Multiple image preview functionality for edit form
        const additionalImagesInput = document.getElementById('additional_images');
        if (additionalImagesInput) {
            additionalImagesInput.addEventListener('change', function(e) {
                const files = Array.from(e.target.files);
                
                // Limit to 5 additional images (plus 1 main = 6 total)
                if (files.length > 5) {
                    alert('You can only upload up to 5 additional images (6 total including main image). Please select fewer images.');
                    e.target.value = ''; // Clear the selection
                    return;
                }
                
                const previewContainer = document.getElementById('image-preview');
                if (!previewContainer) return;
                
                previewContainer.innerHTML = '';
                
                files.forEach((file, index) => {
                    if (file.type.startsWith('image/')) {
                        const reader = new FileReader();
                        
                        reader.onload = function(e) {
                            const previewItem = document.createElement('div');
                            previewItem.className = 'image-preview-item';
                            
                            const img = document.createElement('img');
                            img.src = e.target.result;
                            img.alt = `Preview ${index + 1}`;
                            
                            const removeBtn = document.createElement('button');
                            removeBtn.className = 'remove-image';
                            removeBtn.innerHTML = '×';
                            removeBtn.onclick = function() {
                                previewItem.remove();
                                // Remove file from input
                                const dt = new DataTransfer();
                                const input = document.getElementById('additional_images');
                                const files = Array.from(input.files);
                                files.splice(index, 1);
                                files.forEach(file => dt.items.add(file));
                                input.files = dt.files;
                            };
                            
                            previewItem.appendChild(img);
                            previewItem.appendChild(removeBtn);
                            previewContainer.appendChild(previewItem);
                        };
                        
                        reader.readAsDataURL(file);
                    }
                });
            });
        }

        // Form validation for edit form
        const editForm = document.querySelector('form');
        if (editForm) {
            editForm.addEventListener('submit', function(e) {
                const name = document.querySelector('input[name="name"]').value.trim();
                const description = document.querySelector('textarea[name="description"]').value.trim();
                
                if (!name || !description) {
                    e.preventDefault();
                    alert('Please fill in all required fields (Name and Description)');
                    return false;
                }
                
                // Optional: Check file sizes
                const imageInput = document.querySelector('input[name="image"]');
                const additionalImagesInput = document.getElementById('additional_images');
                
                if (imageInput && imageInput.files[0] && imageInput.files[0].size > 50 * 1024 * 1024) {
                    e.preventDefault();
                    alert('Main image size must be less than 50MB');
                    return false;
                }
                
                if (additionalImagesInput) {
                    for (let file of additionalImagesInput.files) {
                        if (file.size > 50 * 1024 * 1024) {
                            e.preventDefault();
                            alert(`Image ${file.name} size must be less than 50MB`);
                            return false;
                        }
                    }
                }
            });
        }
    });
    </script>
</body>
</html>
