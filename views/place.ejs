<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="deployed" content="2026-04-02-08-15">
<title><%= place.name %> - Ethiopia 361°</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="stylesheet" href="/css/ai-chat.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
    .place-detail {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        background: white;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        border-radius: 8px;
    }
    
    .video-container {
        position: relative;
        padding-bottom: 56.25%;
        height: 0;
        overflow: hidden;
        margin-top: 20px;
    }
    
    .video-container video,
    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }
    
    .place-image {
        width: 100%;
        max-height: 400px;
        object-fit: cover;
        border-radius: 8px;
        margin: 20px 0;
    }
    
    .photo-gallery {
        margin: 30px 0;
    }
    
    .photo-gallery h3 {
        color: var(--primary-color, #004d40);
        margin-bottom: 20px;
        font-size: 1.5rem;
    }
    
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
        margin-bottom: 20px;
    }
    
    .gallery-item {
        position: relative;
        border-radius: 8px;
        overflow: hidden;
        cursor: pointer;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        aspect-ratio: 4/3;
    }
    
    .gallery-item:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }
    
    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }
    
    .gallery-item:hover img {
        transform: scale(1.1);
    }
    
    .gallery-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0,77,64,0.7);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.3s ease;
    }
    
    .gallery-item:hover .gallery-overlay {
        opacity: 1;
    }
    
    .view-icon {
        font-size: 2rem;
        color: white;
    }
    
    .lightbox {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.9);
        z-index: 1000;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }
    
    .lightbox-content {
        position: relative;
        max-width: 90%;
        max-height: 90%;
    }
    
    .lightbox-content img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        border-radius: 8px;
    }
    
    .close-lightbox {
        position: absolute;
        top: -40px;
        right: 0;
        color: white;
        font-size: 3rem;
        cursor: pointer;
        background: none;
        border: none;
        transition: transform 0.3s ease;
    }
    
    .close-lightbox:hover {
        transform: scale(1.2);
    }
    
    .back-btn {
        display: inline-block;
        margin-bottom: 20px;
        color: var(--primary-color, #004d40);
        text-decoration: none;
        font-weight: bold;
    }
    
    /* Map Styles */
    .place-map-section {
        margin: 2rem 0;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    .place-map-section h3 {
        color: var(--primary-color, #004d40);
        margin-bottom: 1rem;
        font-size: 1.3rem;
    }
    #placeMap {
        width: 100%;
        height: 350px;
        border-radius: 12px;
        z-index: 1;
    }
    
    /* Responsive */
    @media (max-width: 768px) {
        .place-detail {
            padding: 1rem;
            margin: 1rem;
        }
        
        .gallery-grid {
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }
        
        .lightbox-content {
            max-width: 95%;
            max-height: 95%;
        }
    }
</style>

<%
// Prepare background image URL
let bgImageUrl = '';
if(place.image_url && place.image_url !== '') {
    if(place.image_url.startsWith('http')) {
        bgImageUrl = place.image_url;
    } else if(place.image_url.startsWith('/uploads/')) {
        bgImageUrl = place.image_url;
    } else {
        bgImageUrl = '/img/' + place.image_url;
    }
}
%>

<style>
    body {
        <% if(bgImageUrl) { %>
        background-image: linear-gradient(rgba(255, 255, 255, 0.85), rgba(255, 255, 255, 0.85)), url('<%- bgImageUrl %>');
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
        <% } %>
    }

    body.dark-mode {
        <% if(bgImageUrl) { %>
        background-image: linear-gradient(rgba(18, 18, 18, 0.85), rgba(18, 18, 18, 0.85)), url('<%- bgImageUrl %>');
        <% } %>
    }

    .place-detail {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(5px);
    }

    body.dark-mode .place-detail {
        background: rgba(30, 30, 30, 0.95);
    }

    .description-section {
        background: rgba(248, 249, 250, 0.9) !important;
    }

    body.dark-mode .description-section {
        background: rgba(40, 40, 40, 0.9) !important;
    }

    .place-map-section {
        background: rgba(255, 255, 255, 0.9);
        padding: 15px;
    }

    body.dark-mode .place-map-section {
        background: rgba(30, 30, 30, 0.9);
    }
</style>

</head>

<body>

<header>
    <h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>
    <nav class="desktop-nav">
        <a href="/" data-en="Home" data-am="ቤት">Home</a>
        <a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
        <a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
        <a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
        <a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
        <a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
        <a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
    </nav>
    <div class="header-right">
        <div class="theme-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode"></div>
        <select id="language" onchange="changeLanguage()">
            <option value="en">English</option>
            <option value="am">አማርኛ</option>
        </select>
        <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>
<nav class="mobile-nav" id="mobile-nav">
    <a href="/" data-en="Home" data-am="ቤት">Home</a>
    <a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
    <a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
    <a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
    <a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
    <a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
    <a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="<%= place.name %>" data-am="<%= place.name_am || place.name %>"><%= place.name %></h2>
        <p data-en="Discover this amazing destination in Ethiopia" data-am="ይህንን የሚያምር የኢትዮጵያን መዳረሻዎች">Discover this amazing destination in Ethiopia</p>
    </div>
</section>

<div class="place-detail">
    <a href="/" class="back-btn">&larr; Back to Destinations</a>
    <h2><%= place.name %></h2>
    
    <% if(place.image_url && place.image_url !== '') { %>
        <% if(place.image_url.startsWith('http')) { %>
            <img src="<%= place.image_url %>" alt="<%= place.name %>" class="place-image" loading="lazy">
        <% } else if(place.image_url.startsWith('/uploads/')) { %>
            <img src="<%= place.image_url %>" alt="<%= place.name %>" class="place-image" loading="lazy">
        <% } else { %>
            <img src="/img/<%= place.image_url %>" alt="<%= place.name %>" class="place-image" loading="lazy">
        <% } %>
    <% } %>
    
    <% if(place && place.description) { %>
        <div class="description-section" style="margin: 2rem 0; padding: 1.5rem; background: #f8f9fa; border-radius: 8px; border-left: 4px solid var(--primary-color, #004d40);">
            <h3 data-en="About This Place" data-am="ስለዚህ ቦታ" style="color: var(--primary-color, #004d40); margin-bottom: 1rem;">About This Place</h3>
            <p style="color: #333; line-height: 1.6; font-size: 1.1rem; margin: 0;"><%= place.description %></p>
        </div>
    <% } else { %>
        <div class="description-section" style="margin: 2rem 0; padding: 1.5rem; background: #f8f9fa; border-radius: 8px; border-left: 4px solid #ccc;">
            <h3 data-en="About This Place" data-am="ስለዚህ ቦታ" style="color: #666; margin-bottom: 1rem;">About This Place</h3>
            <p data-en="Description coming soon..." data-am="መግለጫ በቅርብ ይመጣል..." style="color: #666; font-style: italic;">Description coming soon...</p>
        </div>
    <% } %>
    
    <!-- Location Map Section -->
    <div class="place-map-section">
        <h3><i class="fas fa-map-marked-alt"></i> <span data-en="Location on Map" data-am="በካርታ ላይ ቦታ">Location on Map</span></h3>
        <div id="placeMap"></div>
    </div>
    
    <!-- Photo Gallery Section -->
    <div class="photo-gallery">
        <h3 data-en="Photo Gallery" data-am="ፎቶ ጋለሪ">Photo Gallery</h3>
        <div class="gallery-grid">
            <% 
            // Get gallery images from database - handle both array and JSON string formats
            let galleryImages = [];
            
            if (place.gallery_images) {
                if (Array.isArray(place.gallery_images)) {
                    // New format: stored as array
                    galleryImages = place.gallery_images;
                } else if (typeof place.gallery_images === 'string') {
                    // Old format: stored as JSON string
                    try {
                        galleryImages = JSON.parse(place.gallery_images);
                    } catch (e) {
                        console.log('Error parsing gallery_images:', e);
                    }
                }
            }
            
            // If no gallery images, fall back to main image
            if (galleryImages.length === 0 && place.image_url) {
                if(place.image_url.startsWith('/uploads/')) {
                    galleryImages.push(place.image_url);
                } else {
                    galleryImages.push('/img/' + place.image_url);
                }
            }
            
            console.log('Place detail gallery images:', galleryImages);
            %>
            
            <% galleryImages.forEach((imageSrc, index) => { %>
                <div class="gallery-item" onclick="openLightbox('<%= imageSrc %>')">
                    <img src="<%= imageSrc %>" alt="<%= place.name %> - View <%= index + 1 %>" loading="lazy">
                    <div class="gallery-overlay">
                        <span class="view-icon">🔍</span>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
    
    <!-- Lightbox Modal -->
    <div id="lightbox" class="lightbox" onclick="closeLightbox()">
        <div class="lightbox-content">
            <img id="lightbox-image" src="" alt="Full size image">
            <span class="close-lightbox">&times;</span>
        </div>
    </div>
    
    <% if(place.video_url) { %>
        <div class="video-container">
            <% if(place.video_url.startsWith('/uploads/')) { %>
                <video controls style="width: 100%; height: 400px; border-radius: 8px;">
                    <source src="<%= place.video_url %>" type="video/mp4">
                    Your browser does not support video tag.
                </video>
            <% } else if(place.video_url.includes('youtube.com') || place.video_url.includes('youtu.be')) { %>
                <% 
                // Convert YouTube URL to embed format
                let embedUrl = place.video_url;
                let videoId = '';
                
                if (embedUrl.includes('watch?v=')) {
                    videoId = embedUrl.split('watch?v=')[1].split('&')[0];
                } else if (embedUrl.includes('youtu.be/')) {
                    videoId = embedUrl.split('youtu.be/')[1].split('?')[0];
                }
                
                embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}`;
                %>
                <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px;">
                    <iframe 
                        src="<%= embedUrl %>" 
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 8px;"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen
                        onload="this.style.display='block'; this.nextElementSibling.style.display='none';"
                        onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                    </iframe>
                    <div id="video-fallback" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; box-sizing: border-box;">
                        <i class="fas fa-play-circle" style="font-size: 4rem; color: white; margin-bottom: 1rem;"></i>
                        <h3 style="color: white; margin-bottom: 1rem;">Video Available</h3>
                        <p style="color: white; margin-bottom: 1.5rem; font-size: 0.9rem;">This video is available on YouTube</p>
                        <a href="<%= place.video_url %>" target="_blank" style="display: inline-block; background: white; color: #667eea; padding: 0.75rem 1.5rem; border-radius: 25px; text-decoration: none; font-weight: bold; transition: transform 0.3s ease;">
                            <i class="fab fa-youtube"></i> Watch on YouTube
                        </a>
                    </div>
                </div>
            <% } else { %>
                <video controls style="width: 100%; height: 400px; border-radius: 8px;">
                    <source src="<%= place.video_url %>" type="video/mp4">
                    Your browser does not support video tag.
                </video>
            <% } %>
        </div>
    <% } %>
</div>

<footer>
<p> 2026 Ethiopia 361°</p>
</footer>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="/js/language.js"></script>
<script src="/js/ai-chat.js"></script>
<script>
function toggleMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.querySelector('.mobile-menu-btn');
    
    if (mobileNav.classList.contains('active')) {
        mobileNav.classList.remove('active');
        menuBtn.classList.remove('active');
    } else {
        mobileNav.classList.add('active');
        menuBtn.classList.add('active');
    }
}

function openLightbox(imageSrc) {
    const lightbox = document.getElementById('lightbox');
    const lightboxImage = document.getElementById('lightbox-image');
    
    lightboxImage.src = imageSrc;
    lightbox.style.display = 'flex';
    document.body.style.overflow = 'hidden'; // Prevent scrolling
}

function closeLightbox() {
    const lightbox = document.getElementById('lightbox');
    lightbox.style.display = 'none';
    document.body.style.overflow = 'auto'; // Enable scrolling
}

// Close lightbox with Escape key
document.addEventListener('keydown', function(event) {
    if (event.key === 'Escape') {
        closeLightbox();
    }
});

// Initialize Place Map
const placeCoordinates = {
    'lalibela': { lat: 12.0319, lng: 39.0474 },
    'simien': { lat: 13.2500, lng: 38.4167 },
    'entoto': { lat: 9.0800, lng: 38.7578 },
    'aksum': { lat: 14.1209, lng: 38.7468 },
    'axum': { lat: 14.1209, lng: 38.7468 },
    'gondar': { lat: 12.6030, lng: 37.4521 },
    'harar': { lat: 9.3100, lng: 42.1200 },
    'danakil': { lat: 14.2417, lng: 40.3000 },
    'bahir dar': { lat: 11.5936, lng: 37.3887 },
    'addis ababa': { lat: 9.0222, lng: 38.7468 },
    'addis': { lat: 9.0222, lng: 38.7468 },
    'omo valley': { lat: 5.5000, lng: 36.5000 },
    'omo': { lat: 5.5000, lng: 36.5000 },
    'tana': { lat: 12.0000, lng: 37.2500 },
    'lake tana': { lat: 12.0000, lng: 37.2500 },
    'bale': { lat: 7.0000, lng: 39.7500 },
    'bale mountains': { lat: 7.0000, lng: 39.7500 },
    'tigray': { lat: 14.0323, lng: 38.3166 },
    'sof omar': { lat: 6.9167, lng: 40.8333 },
    'langano': { lat: 7.6000, lng: 38.7167 },
    'lake langano': { lat: 7.6000, lng: 38.7167 },
    'awash': { lat: 8.9833, lng: 40.1667 },
    'dire dawa': { lat: 9.6000, lng: 41.8500 },
    'jimma': { lat: 7.6667, lng: 36.8333 },
    'arba minch': { lat: 6.0333, lng: 37.5500 },
    'blue nile': { lat: 11.4833, lng: 37.5833 },
    'tis abay': { lat: 11.4833, lng: 37.5833 },
    'wenchi': { lat: 8.9333, lng: 37.7833 },
    'debre damo': { lat: 14.3694, lng: 39.1833 },
    'yeha': { lat: 14.2833, lng: 39.0000 }
};

const placeName = '<%= place.name %>'.toLowerCase();
let coords = { lat: 9.0, lng: 38.7 }; // Default: center of Ethiopia

for (const [key, c] of Object.entries(placeCoordinates)) {
    if (placeName.includes(key) || key.includes(placeName.split(' ')[0].toLowerCase())) {
        coords = c;
        break;
    }
}

const placeMap = L.map('placeMap').setView([coords.lat, coords.lng], 10);

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap contributors',
    maxZoom: 18
}).addTo(placeMap);

const markerIcon = L.divIcon({
    className: 'custom-marker',
    html: '<div style="background: linear-gradient(135deg, #004d40, #00796b); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 18px; box-shadow: 0 4px 15px rgba(0,0,0,0.4); border: 3px solid white;">📍</div>',
    iconSize: [40, 40],
    iconAnchor: [20, 20]
});

L.marker([coords.lat, coords.lng], { icon: markerIcon })
    .addTo(placeMap)
    .bindPopup('<strong style="color: #004d40;"><%= place.name %></strong><br><span style="color:#666;"><%= place.category %></span>')
    .openPopup();
</script>
</body>
</html>
