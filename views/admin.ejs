<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Ethiopia 361°</title>
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
    // Wait for DOM to be fully loaded
    document.addEventListener('DOMContentLoaded', function() {
        // Multiple image preview functionality
        const additionalImagesInput = document.getElementById('additional_images');
        if (additionalImagesInput) {
            additionalImagesInput.addEventListener('change', function(e) {
                const files = Array.from(e.target.files);
                
                // Limit to 20 additional images
                if (files.length > 20) {
                    alert('You can only upload up to 20 additional images. Please select fewer images.');
                    e.target.value = ''; // Clear the selection
                    return;
                }
                
                const previewContainer = document.getElementById('image-preview');
                if (!previewContainer) return;
                
                previewContainer.innerHTML = '';
                
                files.forEach((file, index) => {
                    if (file.type.startsWith('image/')) {
                        const reader = new FileReader();
                        
                        reader.onload = function(e) {
                            const previewItem = document.createElement('div');
                            previewItem.className = 'image-preview-item';
                            
                            const img = document.createElement('img');
                            img.src = e.target.result;
                            img.alt = `Preview ${index + 1}`;
                            
                            const removeBtn = document.createElement('button');
                            removeBtn.className = 'remove-image';
                            removeBtn.innerHTML = '×';
                            removeBtn.onclick = function() {
                                previewItem.remove();
                                // Remove file from input
                                const dt = new DataTransfer();
                                const input = document.getElementById('additional_images');
                                const files = Array.from(input.files);
                                files.splice(index, 1);
                                files.forEach(file => dt.items.add(file));
                                input.files = dt.files;
                            };
                            
                            previewItem.appendChild(img);
                            previewItem.appendChild(removeBtn);
                            previewContainer.appendChild(previewItem);
                        };
                        
                        reader.readAsDataURL(file);
                    }
                });
            });
        }

        // Form validation
        const addPlaceForm = document.querySelector('.add-place-form');
        if (addPlaceForm) {
            addPlaceForm.addEventListener('submit', function(e) {
                const name = document.getElementById('name').value.trim();
                const description = document.getElementById('description').value.trim();
                
                if (!name || !description) {
                    e.preventDefault();
                    alert('Please fill in all required fields (Name and Description)');
                    return false;
                }
                
                // Optional: Check file sizes
                const imageInput = document.getElementById('image');
                const additionalImagesInput = document.getElementById('additional_images');
                
                if (imageInput && imageInput.files[0] && imageInput.files[0].size > 50 * 1024 * 1024) {
                    e.preventDefault();
                    alert('Main image size must be less than 50MB');
                    return false;
                }
                
                if (additionalImagesInput) {
                    for (let file of additionalImagesInput.files) {
                        if (file.size > 50 * 1024 * 1024) {
                            e.preventDefault();
                            alert(`Image ${file.name} size must be less than 50MB`);
                            return false;
                        }
                    }
                }
            });
        }
    });
    </script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        .admin-container {
            max-width: 1200px;
            margin: 20px auto;
            padding: 2rem;
        }
        
        .header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            margin-bottom: 2rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .header h2 {
            color: #2c3e50;
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(45deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .header-actions {
            display: flex;
            gap: 1rem;
        }
        
        .stats-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        
        .stat-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 1.5rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.15);
        }
        
        .stat-card i {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            background: linear-gradient(45deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .stat-card h3 {
            color: #2c3e50;
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        
        .stat-card p {
            color: #7f8c8d;
            font-size: 1rem;
        }
        
        .content-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            margin-bottom: 2rem;
        }
        
        .section-title {
            color: #2c3e50;
            font-size: 1.8rem;
            margin-bottom: 1.5rem;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .section-title i {
            color: #667eea;
        }
        
        .table-container {
            overflow-x: auto;
            border-radius: 10px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.05);
        }
        
        table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0;
            background: white;
            border-radius: 10px;
            overflow: hidden;
        }
        
        th {
            background: linear-gradient(45deg, #667eea, #764ba2);
            color: white;
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        td {
            padding: 1rem;
            border-bottom: 1px solid #ecf0f1;
            color: #2c3e50;
        }
        
        tr:hover {
            background-color: #f8f9fa;
        }
        
        tr:last-child td {
            border-bottom: none;
        }
        
        .btn {
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            font-weight: 600;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.3s ease;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .btn-primary {
            background: linear-gradient(45deg, #667eea, #764ba2);
            color: white;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        
        .btn-edit {
            background: linear-gradient(45deg, #3498db, #2980b9);
            color: white;
            box-shadow: 0 4px 15px rgba(52, 152, 219, 0.3);
        }
        
        .btn-edit:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(52, 152, 219, 0.4);
        }
        
        .close-lightbox:hover {
            transform: scale(1.2);
        }
        
        .image-preview-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 10px;
            margin-top: 10px;
        }
        
        .image-preview-item {
            position: relative;
            border-radius: 8px;
            overflow: hidden;
            aspect-ratio: 1;
            border: 2px solid #667eea;
        }
        
        .image-preview-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .image-preview-item .remove-image {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(255, 255, 255, 0.9);
            color: #e74c3c;
            border: none;
            border-radius: 50%;
            width: 25px;
            height: 25px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            transition: all 0.3s ease;
        }
        
        .image-preview-item .remove-image:hover {
            background: #e74c3c;
            color: white;
            transform: scale(1.1);
        }
        
        .btn-danger {
            background: linear-gradient(45deg, #e74c3c, #c0392b);
            color: white;
            box-shadow: 0 4px 15px rgba(231, 76, 60, 0.3);
        }
        
        .btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(231, 76, 60, 0.4);
        }
        
        .btn-secondary {
            background: linear-gradient(45deg, #95a5a6, #7f8c8d);
            color: white;
            box-shadow: 0 4px 15px rgba(149, 165, 166, 0.3);
        }
        
        .btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(149, 165, 166, 0.4);
        }
        
        .form-container {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
            border: 1px solid rgba(255,255,255,0.2);
        }
        
        .form-group {
            margin-bottom: 1.5rem;
        }
        
        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
            color: #2c3e50;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .form-group input, .form-group textarea {
            width: 100%;
            padding: 1rem;
            border: 2px solid #ecf0f1;
            border-radius: 10px;
            font-size: 1rem;
            transition: all 0.3s ease;
            background: white;
        }
        
        .form-group input:focus, .form-group textarea:focus {
            outline: none;
            border-color: #667eea;
            box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.1);
        }
        
        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }
        
        .form-group small {
            display: block;
            margin-top: 0.5rem;
            color: #7f8c8d;
            font-size: 0.8rem;
        }
        
        .form-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
        }
        
        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        
        .empty-state {
            text-align: center;
            padding: 3rem;
            color: #7f8c8d;
        }
        
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 1rem;
            color: #bdc3c7;
        }
        
        @media (max-width: 768px) {
            .admin-container {
                padding: 1rem;
            }
            
            .header {
                flex-direction: column;
                text-align: center;
                gap: 1rem;
            }
            
            .header h2 {
                font-size: 1.5rem;
            }
            
            .header-actions {
                justify-content: center;
            }
            
            .stats-grid {
                grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
                gap: 1rem;
            }
            
            .stat-card {
                padding: 1rem;
            }
            
            .stat-card h3 {
                font-size: 1.2rem;
            }
            
            .add-place-form {
                padding: 1.5rem;
            }
            
            .form-group {
                margin-bottom: 1rem;
            }
            
            .form-group label {
                font-size: 0.9rem;
                margin-bottom: 0.3rem;
            }
            
            .form-group input,
            .form-group select,
            .form-group textarea {
                padding: 0.8rem;
                font-size: 0.9rem;
            }
            
            .form-group textarea {
                min-height: 100px;
            }
            
            .btn {
                padding: 0.8rem 1.5rem;
                font-size: 0.9rem;
            }
            
            .places-grid {
                grid-template-columns: 1fr;
            }
            
            .place-card {
                padding: 1rem;
            }
            
            .place-card h3 {
                font-size: 1.1rem;
            }
            
            .place-card p {
                font-size: 0.85rem;
            }
            
            .place-actions {
                flex-direction: column;
                gap: 0.5rem;
            }
            
            .place-actions a,
            .place-actions button {
                width: 100%;
                text-align: center;
                padding: 0.6rem;
                font-size: 0.85rem;
            }
            
            .image-preview {
                grid-template-columns: repeat(auto-fit, minmax(80px, 1fr));
                gap: 0.5rem;
            }
            
            .image-preview-item {
                width: 80px;
                height: 80px;
            }
            
            .image-preview-item img {
                width: 60px;
                height: 60px;
            }
            
            .remove-image {
                width: 20px;
                height: 20px;
                font-size: 0.8rem;
                line-height: 1;
            }
            
            .table-container {
                font-size: 0.8rem;
                overflow-x: auto;
            }
            
            th, td {
                padding: 0.5rem;
            }
        }
        
        @media (max-width: 480px) {
            .admin-container {
                padding: 0.5rem;
            }
            
            .stats-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.8rem;
            }
            
            .stat-card {
                padding: 0.8rem;
            }
            
            .stat-card h3 {
                font-size: 1rem;
            }
            
            .add-place-form {
                padding: 1rem;
            }
            
            .form-group {
                margin-bottom: 0.8rem;
            }
            
            .form-group input,
            .form-group select,
            .form-group textarea {
                padding: 0.6rem;
                font-size: 0.85rem;
            }
            
            .btn {
                padding: 0.6rem 1rem;
                font-size: 0.85rem;
            }
            
            .image-preview {
                grid-template-columns: repeat(2, 1fr);
                gap: 0.4rem;
            }
            
            .image-preview-item {
                width: 60px;
                height: 60px;
            }
            
            .image-preview-item img {
                width: 40px;
                height: 40px;
            }
        }
        
        @media (max-width: 320px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
            
            .image-preview {
                grid-template-columns: 1fr;
            }
        }
    </style>
<link rel="icon" type="image/jpeg" href="/img/favicon-image.jpg">
</head>
<body>
    <div class="admin-container">
        <div class="header">
            <div>
                <h2><i class="fas fa-tachometer-alt"></i> Admin Dashboard</h2>
                <p style="color: #7f8c8d; margin-top: 0.5rem;">Manage Ethiopia Tourism Content</p>
            </div>
            <div class="header-actions">
                <a href="/" class="btn btn-secondary">
                    <i class="fas fa-home"></i> View Site
                </a>
                <a href="/logout" class="btn btn-danger">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>

        <div class="stats-container">
            <div class="stat-card">
                <i class="fas fa-map-marker-alt"></i>
                <h3><%= places.length %></h3>
                <p>Total Places</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-images"></i>
                <h3><%= places.filter(p => p.image_url).length %></h3>
                <p>With Images</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-video"></i>
                <h3><%= places.filter(p => p.video_url).length %></h3>
                <p>With Videos</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-plus-circle"></i>
                <h3>Active</h3>
                <p>System Status</p>
            </div>
        </div>

        <div class="content-card">
            <h3 class="section-title">
                <i class="fas fa-list"></i>
                Tourist Places Management
            </h3>
            
            <% if(locals.places && places.length > 0) { %>
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th><i class="fas fa-hashtag"></i> ID</th>
                                <th><i class="fas fa-tag"></i> Name</th>
                                <th><i class="fas fa-align-left"></i> Description</th>
                                <th><i class="fas fa-image"></i> Image</th>
                                <th><i class="fas fa-video"></i> Video</th>
                                <th><i class="fas fa-cogs"></i> Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% places.forEach(place => { %>
                            <tr>
                                <td><strong>#<%= place._id %></strong></td>
                                <td><%= place.name %></td>
                                <td>
                                    <% if(place.description && place.description.length > 50) { %>
                                        <%= place.description.substring(0, 50) %>...
                                    <% } else { %>
                                        <%= place.description || 'No description' %>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(place.image_url) { %>
                                        <i class="fas fa-check-circle" style="color: #27ae60;"></i>
                                    <% } else { %>
                                        <i class="fas fa-times-circle" style="color: #e74c3c;"></i>
                                    <% } %>
                                </td>
                                <td>
                                    <% if(place.video_url) { %>
                                        <i class="fas fa-check-circle" style="color: #27ae60;"></i>
                                    <% } else { %>
                                        <i class="fas fa-times-circle" style="color: #e74c3c;"></i>
                                    <% } %>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <form action="/admin/edit/<%= place._id %>" method="GET" style="display:inline;">
                                            <button type="submit" class="btn btn-edit">
                                                <i class="fas fa-edit"></i> Edit
                                            </button>
                                        </form>
                                        <form action="/admin/delete/<%= place._id %>" method="POST" style="display:inline;">
                                            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this place?')">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fas fa-map-marked-alt"></i>
                    <h3>No Places Added Yet</h3>
                    <p>Start by adding your first tourist destination!</p>
                </div>
            <% } %>
        </div>

        <div class="form-container">
            <h3 class="section-title">
                <i class="fas fa-plus-circle"></i>
                Add New Tourist Place
            </h3>
            
            <form action="/admin/add" method="POST" enctype="multipart/form-data">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
                    <div class="form-group">
                        <label for="name">
                            <i class="fas fa-tag"></i> Place Name
                        </label>
                        <input type="text" id="name" name="name" required placeholder="e.g., Lalibela Rock-Hewn Churches">
                    </div>
                    
                    <div class="form-group">
                        <label for="category">
                            <i class="fas fa-list"></i> Category
                        </label>
                        <select id="category" name="category" required>
                            <option value="">Select Category</option>
                            <option value="Historical & Cultural Sites">🏛️ Historical & Cultural Sites</option>
                            <option value="Nature & Mountains">🌄 Nature & Mountains</option>
                            <option value="Unique & Adventure Destinations">🌋 Unique & Adventure Destinations</option>
                            <option value="Lakes & Water Attractions">🌊 Lakes & Water Attractions</option>
                            <option value="Cities & Urban Tourism">🏙️ Cities & Urban Tourism</option>
                            <option value="Relaxation & Resort Areas">🌿 Relaxation & Resort Areas</option>
                        </select>
                    </div>
                    
                    <div class="form-group" style="grid-column: 1 / -1;">
                        <label for="description">
                            <i class="fas fa-align-left"></i> Description
                        </label>
                        <textarea id="description" name="description" rows="4" required placeholder="Describe this amazing place..."></textarea>
                    </div>
                    
                    <!-- Amharic Translation Fields -->
                    <div style="margin-top: 1.5rem; padding: 1rem; background: #fff3cd; border-radius: 8px; border: 1px solid #ffeaa7;">
                        <h4 style="margin-bottom: 1rem; color: #856404;">
                            <i class="fas fa-language"></i> Amharic Translation (አማርኛ ትርጉም)
                        </h4>
                        
                        <div class="form-group">
                            <label for="name_am">
                                <i class="fas fa-globe"></i> Name in Amharic (ስም በአማርኛ)
                            </label>
                            <input type="text" id="name_am" name="name_am" placeholder="ለምሳሌ: ላሊበላ የተቀደሱ የእንጨት ቤተ ክርስቲያኖች">
                            <small>Optional - Leave empty to use English name</small>
                        </div>
                        
                        <div class="form-group">
                            <label for="description_am">
                                <i class="fas fa-globe"></i> Description in Amharic (መግለጫ በአማርኛ)
                            </label>
                            <textarea id="description_am" name="description_am" rows="4" placeholder="ይህንን ቦታ በአማርኛ ይግለጹ..."></textarea>
                            <small>Optional - Leave empty to use English description</small>
                        </div>
                    </div>
                    
                    <div class="form-group">
                        <label for="image">
                            <i class="fas fa-image"></i> Main Image
                        </label>
                        <input type="file" id="image" name="image" accept="image/*">
                        <small>Supported formats: JPG, PNG, GIF, WebP (Max 50MB)</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="image_url">
                            <i class="fas fa-link"></i> Or Main Image URL
                        </label>
                        <input type="text" id="image_url" name="image_url" placeholder="e.g., lalibela.jpg">
                        <small>If no file uploaded, this will be used</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="additional_images">
                            <i class="fas fa-images"></i> Additional Images (Gallery)
                        </label>
                        <input type="file" id="additional_images" name="additional_images" accept="image/*" multiple>
                        <small>Select up to 20 additional images for photo gallery (Max 50MB each)</small>
                        <div id="image-preview" class="image-preview-container"></div>
                    </div>
                    
                    <div class="form-group">
                        <label for="video">
                            <i class="fas fa-video"></i> Upload Video
                        </label>
                        <input type="file" id="video" name="video" accept="video/*">
                        <small>Supported formats: MP4, WebM, OGG (Max 50MB)</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="video_url">
                            <i class="fas fa-link"></i> Or Video URL
                        </label>
                        <input type="text" id="video_url" name="video_url" placeholder="https://www.youtube.com/embed/VIDEO_ID">
                        <small>YouTube embed URL preferred</small>
                    </div>
                    
                    <div class="form-group">
                        <label for="description_pdf">
                            <i class="fas fa-file-pdf"></i> Description PDF (Optional)
                        </label>
                        <input type="file" id="description_pdf" name="description_pdf" accept=".pdf">
                        <small>Upload PDF file for detailed description (Max 10MB)</small>
                    </div>
                </div>
                
                <!-- Travel Guide Section -->
                <div style="margin-top: 2rem; padding: 1.5rem; background: #f8f9fa; border-radius: 8px;">
                    <h4 style="margin-bottom: 1rem; color: #2c3e50;">
                        <i class="fas fa-map-signs"></i> Travel Guide Information
                    </h4>
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1rem;">
                        <div class="form-group">
                            <label for="best_time_to_visit">
                                <i class="fas fa-calendar-alt"></i> Best Time to Visit
                            </label>
                            <input type="text" id="best_time_to_visit" name="best_time_to_visit" placeholder="e.g., October to March">
                        </div>
                        
                        <div class="form-group">
                            <label for="how_to_get_there">
                                <i class="fas fa-route"></i> How to Get There
                            </label>
                            <input type="text" id="how_to_get_there" name="how_to_get_there" placeholder="e.g., Fly to Lalibela Airport">
                        </div>
                        
                        <div class="form-group">
                            <label for="what_to_bring">
                                <i class="fas fa-backpack"></i> What to Bring
                            </label>
                            <input type="text" id="what_to_bring" name="what_to_bring" placeholder="e.g., Comfortable shoes, camera">
                        </div>
                        
                        <div class="form-group">
                            <label for="local_tips">
                                <i class="fas fa-lightbulb"></i> Local Tips
                            </label>
                            <input type="text" id="local_tips" name="local_tips" placeholder="e.g., Hire local guide">
                        </div>
                        
                        <div class="form-group">
                            <label for="entrance_fees">
                                <i class="fas fa-ticket-alt"></i> Entrance Fees
                            </label>
                            <input type="text" id="entrance_fees" name="entrance_fees" placeholder="e.g., 1000 ETB for foreigners">
                        </div>
                        
                        <div class="form-group">
                            <label for="opening_hours">
                                <i class="fas fa-clock"></i> Opening Hours
                            </label>
                            <input type="text" id="opening_hours" name="opening_hours" placeholder="e.g., 8:00 AM - 6:00 PM">
                        </div>
                        
                        <div class="form-group">
                            <label for="accommodation">
                                <i class="fas fa-bed"></i> Accommodation
                            </label>
                            <input type="text" id="accommodation" name="accommodation" placeholder="e.g., Hotels and guesthouses available">
                        </div>
                        
                        <div class="form-group">
                            <label for="nearby_attractions">
                                <i class="fas fa-map-marked"></i> Nearby Attractions
                            </label>
                            <input type="text" id="nearby_attractions" name="nearby_attractions" placeholder="e.g., Yemrehana Kristos Church">
                        </div>
                    </div>
                </div>
                
                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-plus-circle"></i> Add Place
                    </button>
                    <button type="reset" class="btn btn-secondary">
                        <i class="fas fa-redo"></i> Reset Form
                    </button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>
