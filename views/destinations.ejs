<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Destinations - Ethiopia 361°</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="css/ai-chat.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"></script>
</head>

<body>

<header>
<h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>

<div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
        <span></span>
        <span></span>
        <span></span>
    </button>
</div>

<nav class="desktop-nav">
<a href="/" data-en="Home" data-am="ቤት">Home</a>
<a href="/destinations" class="active" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
<a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
<a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
<a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
<a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
<a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<nav class="mobile-nav" id="mobile-nav">
<a href="/" data-en="Home" data-am="ቤት">Home</a>
<a href="/destinations" class="active" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
<a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
<a href="/gallery" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
<a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
<a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
<a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<div class="theme-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode"></div>

<select id="language" onchange="changeLanguage()">
<option value="en">English</option>
<option value="am">አማርኛ</option>
</select>

</header>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Explore Ethiopian Destinations" data-am="የኢትዮጵያ መዳረሻዎችን ያስሱ">Explore Ethiopian Destinations</h2>
        <p data-en="Discover amazing places across Ethiopia" data-am="በኢትዮጵያ ውስጥ ያለው የሚያምር ቦታዎችን ያግኙ">Discover amazing places across Ethiopia</p>
    </div>
</section>

<!-- Search Bar -->
<section style="padding: 2rem; max-width: 800px; margin: 0 auto;">
    <div class="search-container" style="position: relative;">
        <input type="text" id="searchInput" placeholder="Search destinations..." data-en-placeholder="Search destinations..." data-am-placeholder="መዳረሻዎችን ይፈለ..." style="width: 100%; padding: 15px 20px; border: 2px solid #e0e0e0; border-radius: 12px; font-size: 1rem; outline: none; transition: all 0.3s ease;">
        <i class="fas fa-search" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: #888;"></i>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section" style="padding: 2rem; max-width: 1200px; margin: 0 auto;">
    <h2 data-en="Browse by Category" data-am="በምድግ ይዝርዱ" style="text-align: center; margin-bottom: 2rem; color: var(--primary-color);">Browse by Category</h2>
    <div class="category-filters" style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;">
        <button class="category-btn active" data-category="all" data-en="All" data-am="ሁሉን">All</button>
        <button class="category-btn" data-category="Historical" data-en="Historical" data-am="ታሪክ">Historical</button>
        <button class="category-btn" data-category="Nature" data-en="Nature" data-am="ተፈሪ">Nature</button>
        <button class="category-btn" data-category="Lakes" data-en="Lakes" data-am="ሀይቆዎች">Lakes</button>
        <button class="category-btn" data-category="Cities" data-en="Cities" data-am="ከተማዎች">Cities</button>
        <button class="category-btn" data-category="Adventure" data-en="Adventure" data-am="የጉዞ">Adventure</button>
        <button class="category-btn" data-category="Cultural" data-en="Cultural" data-am="ባህል">Cultural</button>
        <button class="category-btn" data-category="Religious" data-en="Religious" data-am="ሃይማኖት">Religious</button>
    </div>
</section>

<!-- Destinations Grid -->
<section class="places-grid">
<div class="grid-container" id="destinationsContent">
    <!-- Destinations will be loaded here -->
</div>
</section>

<script src="/js/language.js"></script>
<script>
let allPlaces = [];
let currentCategory = 'all';

// Load destinations from database
async function loadDestinations() {
    try {
        const response = await fetch('/api/places');
        const places = await response.json();
        
        console.log('Loaded places:', places.length);
        
        // Show all places (removed slice that was skipping first 10)
        allPlaces = places;
        displayDestinations(allPlaces);
    } catch (error) {
        console.error('Error loading destinations:', error);
        document.getElementById('destinationsContent').innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later" data-am="እባኮላ በኋላ ይሞክሉ">Please try again later</p>
            </div>
        `;
    }
}

// Display destinations with filtering
function displayDestinations(places) {
    const container = document.getElementById('destinationsContent');
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    
    // Filter by category and search
    let filteredPlaces = places.filter(place => {
        const matchesCategory = currentCategory === 'all' || place.category === currentCategory;
        const matchesSearch = !searchTerm || 
            place.name.toLowerCase().includes(searchTerm) ||
            (place.name_am && place.name_am.toLowerCase().includes(searchTerm)) ||
            place.description.toLowerCase().includes(searchTerm) ||
            (place.description_am && place.description_am.toLowerCase().includes(searchTerm));
        return matchesCategory && matchesSearch;
    });

    if (filteredPlaces.length === 0) {
        container.innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-search" style="font-size: 4rem; color: #888; margin-bottom: 1rem;"></i>
                <h3 data-en="No Destinations Found" data-am="ምንም መዳረሻ አልተገኘ">No Destinations Found</h3>
                <p data-en="Try adjusting your filters" data-am="ማጣልዎችን ይቀይሩ">Try adjusting your filters</p>
            </div>
        `;
        return;
    }

    // Group by category
    const groupedPlaces = {};
    filteredPlaces.forEach(place => {
        if (!groupedPlaces[place.category]) {
            groupedPlaces[place.category] = [];
        }
        groupedPlaces[place.category].push(place);
    });

    // Display grouped places
    let html = '';
    Object.keys(groupedPlaces).forEach(category => {
        html += `
            <div class="category-section" style="margin-bottom: 3rem;">
                <h3 style="color: var(--primary-color); margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                    <span>${getCategoryIcon(category)}</span>
                    <span data-en="${category}" data-am="${getCategoryAmharic(category)}">${category}</span>
                </h3>
                <div class="grid-container">
        `;
        
        groupedPlaces[category].forEach(place => {
            html += `
                <div class="card">
                    ${place.image_url ? `
                        ${place.image_url.startsWith('http') 
                            ? `<img src="${place.image_url}" alt="${place.name}" class="place-img">`
                            : place.image_url.startsWith('/uploads/') 
                            ? `<img src="${place.image_url}" alt="${place.name}" class="place-img">`
                            : `<img src="/img/${place.image_url}" alt="${place.name}" class="place-img" onerror="this.src='https://picsum.photos/seed/${place.name}/400/300.jpg'">`
                        }
                    ` : `
                        <img src="https://picsum.photos/seed/${place.name}/400/300.jpg" alt="${place.name}" class="place-img">
                    `}
                    <h3 data-en="${place.name}" data-am="${place.name_am || place.name}">${place.name}</h3>
                    <p class="place-description">
                        <span class="short-text" data-en="${place.description ? place.description.substring(0, 150) + '...' : 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am ? place.description_am.substring(0, 150) + '...' : 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description ? place.description.substring(0, 150) + '...' : 'Discover this amazing destination in Ethiopia'}</span>
                        <span class="full-text" style="display: none;" data-en="${place.description || 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am || 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description || 'Discover this amazing destination in Ethiopia'}</span>
                    </p>
                    <div class="card-actions">
                        <button class="btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                        <a href="/place/${place._id}" class="btn-view-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                        ${place.video_url ? `
                            <button class="btn-read-more" onclick="showVideo('${place.video_url}', '${place.name}')" style="background-color: var(--secondary-color); color: var(--text-dark);">
                                <i class="fas fa-play"></i> <span data-en="Watch Video" data-am="ቪዲዮውን ይመልከቱ">Watch Video</span>
                            </button>
                        ` : ''}
                        ${place.description_pdf ? `
                            <a href="${place.description_pdf}" target="_blank" class="btn-read-more" style="background-color: #e74c3c; color: white; text-decoration: none;">
                                <i class="fas fa-file-pdf"></i> <span data-en="Download PDF" data-am="PDF ያውርዱ">Download PDF</span>
                            </a>
                        ` : ''}
                    </div>
                </div>
            `;
        });
        
        html += `
                </div>
            </div>
        `;
    });

    container.innerHTML = html;
}

// Helper functions
function getCategoryIcon(category) {
    const icons = {
        'Historical': '🏛️',
        'Historical & Cultural Sites': '🏛️',
        'Nature': '🌄',
        'Nature & Mountains': '🌄',
        'Adventure': '🌋',
        'Unique & Adventure Destinations': '🌋',
        'Lakes': '🌊',
        'Lakes & Water Attractions': '🌊',
        'Cities': '🏙️',
        'Cities & Urban Tourism': '🏙️',
        'Relaxation': '🌿',
        'Relaxation & Resort Areas': '🌿',
        'Cultural': '🏛️',
        'Religious': '⛪'
    };
    return icons[category] || icons[category.replace(/ &.*/, '')] || '📍';
}

function getCategoryAmharic(category) {
    const amharic = {
        'Historical': 'ታሪካዊ',
        'Historical & Cultural Sites': 'ታሪክ፣ እና የባህልነት ቦታዎች',
        'Nature': 'ተፈሪ',
        'Nature & Mountains': 'ተፈሪ እና ተራሮች',
        'Adventure': 'ጉዞ',
        'Unique & Adventure Destinations': 'የተለየ እና የጉዞ መዳረሻዎች',
        'Lakes': 'ሀይቆች',
        'Lakes & Water Attractions': 'ሀይቆዎች እና የውሃሳት መስልከቶች',
        'Cities': 'ከተማዎች',
        'Cities & Urban Tourism': 'ከተማዎች እና የከተማ ቱራርኛ',
        'Relaxation': 'መዝናት',
        'Relaxation & Resort Areas': 'መዝናት እና የምርርባ ቦታዎች',
        'Cultural': 'ባህላዊ',
        'Religious': 'ሃይማኖታዊ'
    };
    return amharic[category] || amharic[category.replace(/ &.*/, '')] || category;
}

// Toggle read more
function toggleReadMore(button) {
    const card = button.closest('.card');
    const shortText = card.querySelector('.short-text');
    const fullText = card.querySelector('.full-text');
    
    if (shortText.style.display === 'none') {
        shortText.style.display = 'inline';
        fullText.style.display = 'none';
        button.innerHTML = button.getAttribute('data-en') === 'Read More' ? 'Read More' : 'ተጨማሪ ያንብቡ';
    } else {
        shortText.style.display = 'none';
        fullText.style.display = 'inline';
        button.innerHTML = button.getAttribute('data-en') === 'Read More' ? 'Read Less' : 'ተነባይ ያንብቡ';
    }
}

// Show video modal
function showVideo(videoUrl, placeName) {
    const modal = document.createElement('div');
    modal.style.cssText = `
        position: fixed; top: 0; left: 0; width: 100%; height: 100%; 
        background: rgba(0,0,0,0.8); z-index: 1000; display: flex; 
        align-items: center; justify-content: center;
    `;
    
    modal.innerHTML = `
        <div style="background: white; padding: 2rem; border-radius: 12px; max-width: 800px; width: 90%;">
            <h3 style="margin-bottom: 1rem;">${placeName}</h3>
            <iframe src="${videoUrl}" style="width: 100%; height: 400px; border: none; border-radius: 8px;"></iframe>
            <button onclick="this.parentElement.parentElement.remove()" style="margin-top: 1rem; padding: 10px 20px; background: var(--primary-color); color: white; border: none; border-radius: 5px; cursor: pointer;">Close</button>
        </div>
    `;
    
    document.body.appendChild(modal);
}

// Event listeners
document.addEventListener('DOMContentLoaded', function() {
    loadDestinations();
    
    // Search functionality
    document.getElementById('searchInput').addEventListener('input', function() {
        displayDestinations(allPlaces);
    });
    
    // Category filter buttons
    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentCategory = this.getAttribute('data-category');
            displayDestinations(allPlaces);
        });
    });
});

function toggleMobileMenu() {
    const nav = document.getElementById('mobile-nav');
    nav.classList.toggle('active');
}
</script>

<style>
.category-btn {
    padding: 12px 24px;
    background: white;
    border: 2px solid var(--primary-color);
    border-radius: 25px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
    color: var(--primary-color);
}

.category-btn:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-2px);
}

.category-btn.active {
    background: var(--primary-color);
    color: white;
}

.category-section {
    border-bottom: 1px solid #e0e0e0;
    padding-bottom: 2rem;
}

.search-container input:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(0,77,64,0.1);
}
</style>

<footer>
<p> 2026 Ethiopia 361°</p>
</footer>

<script src="js/language.js"></script>
<script src="js/ai-chat.js"></script>

</body>
</html>