<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Explore Ethiopian Destinations" data-am="የኢትዮጵያ መዳረሻዎችን ያስሱ">Explore Ethiopian Destinations</h2>
        <p data-en="Discover amazing places across Ethiopia" data-am="በኢትዮጵያ ውስጥ ያለው የሚያምር ቦታዎችን ያግኙ">Discover amazing places across Ethiopia</p>
    </div>
</section>

<!-- Search Bar -->
<section style="padding: 2rem; max-width: 800px; margin: 0 auto;">
    <div class="search-container" style="position: relative;">
        <input type="text" id="searchInput" placeholder="Search destinations..." data-en-placeholder="Search destinations..." data-am-placeholder="መዳረሻዎችን ይፈለ..." style="width: 100%; padding: 15px 20px; border: 2px solid #e0e0e0; border-radius: 12px; font-size: 1rem; outline: none; transition: all 0.3s ease;">
        <i class="fas fa-search" style="position: absolute; right: 20px; top: 50%; transform: translateY(-50%); color: #888;"></i>
    </div>
</section>

<!-- Categories Section -->
<section class="categories-section" style="padding: 2rem; max-width: 1200px; margin: 0 auto;">
    <h2 data-en="Browse by Category" data-am="በምድግ ይዝርዱ" style="text-align: center; margin-bottom: 2rem; color: #000;">Browse by Category</h2>
    <div class="category-filters" style="display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; margin-bottom: 2rem;">
        <button class="category-btn active" data-category="all" data-en="All" data-am="ሁሉን">All</button>
        <button class="category-btn" data-category="Historical" data-en="Historical" data-am="ታሪክ">Historical</button>
        <button class="category-btn" data-category="Nature" data-en="Nature" data-am="ተፈሪ">Nature</button>
        <button class="category-btn" data-category="Lakes" data-en="Lakes" data-am="ሀይቆዎች">Lakes</button>
        <button class="category-btn" data-category="Cities" data-en="Cities" data-am="ከተማዎች">Cities</button>
        <button class="category-btn" data-category="Adventure" data-en="Adventure" data-am="የጉዞ">Adventure</button>
        <button class="category-btn" data-category="Cultural" data-en="Cultural" data-am="ባህል">Cultural</button>
        <button class="category-btn" data-category="Religious" data-en="Religious" data-am="ሃይማኖት">Religious</button>
    </div>
</section>

<!-- Destinations Grid -->
<section class="places-grid">
<div class="grid-container" id="destinationsContent">
    <!-- Loading spinner -->
    <div id="destinationsLoader" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
        <div style="display: inline-block; width: 50px; height: 50px; border: 4px solid #e0e0e0; border-top-color: #000; border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
        <p style="margin-top: 1rem; color: #888;" data-en="Loading destinations..." data-am="መዳረሻዎችን በመጫን ላይ...">Loading destinations...</p>
    </div>
    <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
</div>
<div id="pagination" style="width: 100%; display: flex; justify-content: center; margin-top: 2rem;">
    <!-- Pagination controls will be added here -->
</div>
</section>

<script src="/js/language.js"></script>
<script>
let allPlaces = [];
let currentCategory = 'all';
let currentPage = 1;
const placesPerPage = 6;

// Load destinations from database
async function loadDestinations() {
    try {
        const response = await fetch('/api/places');
        const places = await response.json();
        
        console.log('Loaded places:', places.length);
        
        // Show all places (removed slice that was skipping first 10)
        allPlaces = places;
        // Remove loader
        const loader = document.getElementById('destinationsLoader');
        if (loader) loader.remove();
        displayDestinations(allPlaces);
    } catch (error) {
        console.error('Error loading destinations:', error);
        document.getElementById('destinationsContent').innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later" data-am="እባኮላ በኋላ ይሞክሉ">Please try again later</p>
            </div>
        `;
    }
}

// Display destinations with filtering
function displayDestinations(places) {
    const container = document.getElementById('destinationsContent');
    const searchTerm = document.getElementById('searchInput').value.toLowerCase();
    const currentCategory = document.querySelector('.category-btn.active').getAttribute('data-category');
    
    // Filter places
    let filteredPlaces = places.filter(place => {
        const matchesCategory = currentCategory === 'all' || 
            place.category.toLowerCase().includes(currentCategory.toLowerCase()) ||
            currentCategory.toLowerCase().includes(place.category.toLowerCase());
        const matchesSearch = !searchTerm || 
            place.name.toLowerCase().includes(searchTerm) || 
            (place.name_am && place.name_am.toLowerCase().includes(searchTerm)) ||
            place.description.toLowerCase().includes(searchTerm) ||
            (place.description_am && place.description_am.toLowerCase().includes(searchTerm));
        return matchesCategory && matchesSearch;
    });

    if (filteredPlaces.length === 0) {
        container.innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-search" style="font-size: 4rem; color: #888; margin-bottom: 1rem;"></i>
                <h3 data-en="No Destinations Found" data-am="ምንም መዳረሻ አልተገኘ">No Destinations Found</h3>
                <p data-en="Try adjusting your filters" data-am="ማጣልዎችን ይቀይሩ">Try adjusting your filters</p>
            </div>
        `;
        document.getElementById('pagination').innerHTML = '';
        if (typeof updateLanguage === 'function') {
            updateLanguage(localStorage.getItem('selectedLanguage') || 'en');
        }
        return;
    }

    // Calculate pagination
    const totalPages = Math.ceil(filteredPlaces.length / placesPerPage);
    const startIndex = (currentPage - 1) * placesPerPage;
    const endIndex = startIndex + placesPerPage;
    const paginatedPlaces = filteredPlaces.slice(startIndex, endIndex);

    let html = '';

    // Group places by category if not 'all'
    if (currentCategory === 'all') {
        html = '<div class="grid-container">';
        paginatedPlaces.forEach(place => {
            html += generatePlaceCard(place);
        });
        html += '</div>';
    } else {
        const groupedPlaces = paginatedPlaces.reduce((acc, place) => {
            const category = place.category || 'Other';
            if (!acc[category]) acc[category] = [];
            acc[category].push(place);
            return acc;
        }, {});

        for (const [category, categoryPlaces] of Object.entries(groupedPlaces)) {
            html += `
                <div class="category-section" style="grid-column: 1 / -1; margin-bottom: 3rem;">
                    <h2 class="category-title" style="margin-bottom: 2rem; color: #000; border-bottom: 2px solid var(--primary-color); padding-bottom: 0.5rem; display: inline-block;">
                        <span style="font-size: 1.5rem; margin-right: 0.5rem;">${getCategoryIcon(category)}</span>
                        <span data-en="${category}" data-am="${getCategoryAmharic(category)}">${category}</span>
                    </h2>
                    <div class="grid-container">
            `;

            categoryPlaces.forEach(place => {
                html += generatePlaceCard(place);
            });

            html += `
                    </div>
                </div>
            `;
        }
    }

    container.innerHTML = html;
    
    // Add pagination controls
    if (totalPages > 1) {
        const paginationHtml = `
            <div class="pagination-controls" style="display: flex; justify-content: center; align-items: center; gap: 1rem;">
                <button onclick="changePage(${currentPage - 1})" 
                        class="pagination-btn" 
                        ${currentPage === 1 ? 'disabled' : ''}
                        data-en="Previous" data-am="ቀደም">
                    <i class="fas fa-chevron-left"></i> Previous
                </button>
                <span class="page-info" style="font-weight: bold; color: var(--primary);">
                    Page ${currentPage} of ${totalPages}
                </span>
                <button onclick="changePage(${currentPage + 1})" 
                        class="pagination-btn" 
                        ${currentPage === totalPages ? 'disabled' : ''}
                        data-en="Next" data-am="ይቀጥሉ">
                    Next <i class="fas fa-chevron-right"></i>
                </button>
            </div>
        `;
        document.getElementById('pagination').innerHTML = paginationHtml;
    } else {
        document.getElementById('pagination').innerHTML = '';
    }

    if (typeof updateLanguage === 'function') {
        updateLanguage(localStorage.getItem('selectedLanguage') || 'en');
    }
}

function generatePlaceCard(place) {
    return `
        <div class="card">
            ${place.image_url ? `
                <img src="${place.image_url.startsWith('http') || place.image_url.startsWith('/') ? place.image_url : '/img/' + place.image_url}" alt="${place.name}" class="place-img" loading="lazy" onerror="this.onerror=null; this.src='/img/placeholder.jpg';">
            ` : `
                <img src="/img/placeholder.jpg" alt="${place.name}" class="place-img" loading="lazy">
            `}
            <h3 data-en="${place.name}" data-am="${place.name_am || place.name}">${place.name}</h3>
            <p class="place-description">
                <span class="short-text" data-en="${place.description ? place.description.substring(0, 120) + '...' : 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am ? place.description_am.substring(0, 120) + '...' : 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description ? place.description.substring(0, 120) + '...' : 'Discover this amazing destination in Ethiopia'}</span>
                <span class="full-text" style="display: none;" data-en="${place.description || 'Discover this amazing destination in Ethiopia'}" data-am="${place.description_am || 'ይህንን የሚያምር የኢትዮጵያን መዳረሻ ያግኙ'}">${place.description || 'Discover this amazing destination in Ethiopia'}</span>
            </p>
            <div class="card-actions">
                <button class="btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                <a href="/place/${place._id}" class="btn-view-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                ${place.video_url ? `
                    <button class="btn-read-more" onclick="showVideo('${place.video_url}', '${place.name}')" style="background-color: var(--secondary-color); color: var(--text-dark);">
                        <i class="fas fa-play"></i> <span data-en="Watch Video" data-am="ቪዲዮውን ይመልከቱ">Watch Video</span>
                    </button>
                ` : ''}
                ${place.description_pdf ? `
                    <a href="${place.description_pdf}" target="_blank" class="btn-read-more" style="background-color: #e74c3c; color: white; text-decoration: none;">
                        <i class="fas fa-file-pdf"></i> <span data-en="Download PDF" data-am="PDF ያውርዱ">Download PDF</span>
                    </a>
                ` : ''}
            </div>
        </div>
    `;
}

// Change page function
function changePage(page) {
    const totalPages = Math.ceil(allPlaces.length / placesPerPage);
    if (page >= 1 && page <= totalPages) {
        currentPage = page;
        displayDestinations(allPlaces);
        // Scroll to top of destinations
        document.getElementById('destinationsContent').scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
}

// Helper functions
function getCategoryIcon(category) {
    const icons = {
        'Historical': '🏛️',
        'Historical & Cultural Sites': '🏛️',
        'Nature': '🌄',
        'Nature & Mountains': '🌄',
        'Adventure': '🌋',
        'Unique & Adventure Destinations': '🌋',
        'Lakes': '🌊',
        'Lakes & Water Attractions': '🌊',
        'Cities': '🏙️',
        'Cities & Urban Tourism': '🏙️',
        'Relaxation': '🌿',
        'Relaxation & Resort Areas': '🌿',
        'Cultural': '🏛️',
        'Religious': '⛪'
    };
    return icons[category] || icons[category.replace(/ &.*/, '')] || '📍';
}

function getCategoryAmharic(category) {
    const amharic = {
        'Historical': 'ታሪካዊ',
        'Historical & Cultural Sites': 'ታሪክ፣ እና የባህልነት ቦታዎች',
        'Nature': 'ተፈሪ',
        'Nature & Mountains': 'ተፈሪ እና ተራሮች',
        'Adventure': 'ጉዞ',
        'Unique & Adventure Destinations': 'የተለየ እና የጉዞ መዳረሻዎች',
        'Lakes': 'ሀይቆች',
        'Lakes & Water Attractions': 'ሀይቆዎች እና የውሃሳት መስልከቶች',
        'Cities': 'ከተማዎች',
        'Cities & Urban Tourism': 'ከተማዎች እና የከተማ ቱራርኛ',
        'Relaxation': 'መዝናት',
        'Relaxation & Resort Areas': 'መዝናት እና የምርርባ ቦታዎች',
        'Cultural': 'ባህላዊ',
        'Religious': 'ሃይማኖታዊ'
    };
    return amharic[category] || amharic[category.replace(/ &.*/, '')] || category;
}

// Toggle read more
function toggleReadMore(button) {
    const card = button.closest('.card');
    const shortText = card.querySelector('.short-text');
    const fullText = card.querySelector('.full-text');
    const currentLang = localStorage.getItem('selectedLanguage') || 'en';
    
    if (shortText.style.display === 'none') {
        shortText.style.display = 'inline';
        fullText.style.display = 'none';
        button.setAttribute('data-en', 'Read More');
        button.setAttribute('data-am', 'ተጨማሪ ያንብቡ');
        button.textContent = currentLang === 'am' ? 'ተጨማሪ ያንብቡ' : 'Read More';
    } else {
        shortText.style.display = 'none';
        fullText.style.display = 'inline';
        button.setAttribute('data-en', 'Read Less');
        button.setAttribute('data-am', 'ያነሰ ያንብቡ');
        button.textContent = currentLang === 'am' ? 'ያነሰ ያንብቡ' : 'Read Less';
    }
}

// Show video modal
function showVideo(videoUrl, placeName) {
    const modal = document.createElement('div');
    modal.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 10000;
        display: flex;
        align-items: center;
        justify-content: center;
    `;
    
    modal.innerHTML = `
        <div style="background: white; border-radius: 16px; max-width: 800px; width: 90%; max-height: 90vh; position: relative;">
            <div style="padding: 2rem; border-bottom: 1px solid #e0e0e0;">
                <h3 style="margin: 0; color: #000;">${placeName}</h3>
                <button onclick="this.closest('.video-modal').remove()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 1.5rem; cursor: pointer; color: #999;">×</button>
            </div>
            <div style="padding: 2rem; text-align: center;">
                ${videoUrl.includes('youtube.com') || videoUrl.includes('youtu.be') ?
                    (() => {
                        let videoId = '';
                        let embedUrl = videoUrl;

                        if (videoUrl.includes('watch?v=')) {
                            videoId = videoUrl.split('watch?v=')[1].split('&')[0];
                        } else if (videoUrl.includes('youtu.be/')) {
                            videoId = videoUrl.split('youtu.be/')[1].split('?')[0];
                        }

                        embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}`;

                        return `
                            <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: 8px;">
                                <iframe
                                    src="${embedUrl}"
                                    style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: none; border-radius: 8px;"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen
                                    onload="this.style.display='block'; this.nextElementSibling.style.display='none';"
                                    onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
                                </iframe>
                                <div style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 8px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem; box-sizing: border-box;">
                                    <i class="fas fa-play-circle" style="font-size: 3rem; color: white; margin-bottom: 1rem;"></i>
                                    <h3 style="color: white; margin-bottom: 0.5rem;">Video Available</h3>
                                    <p style="color: white; margin-bottom: 1rem; font-size: 0.9rem;">This video is available on YouTube</p>
                                    <a href="${videoUrl}" target="_blank" style="display: inline-block; background: white; color: #667eea; padding: 0.5rem 1rem; border-radius: 20px; text-decoration: none; font-weight: bold;">
                                        <i class="fab fa-youtube"></i> Watch on YouTube
                                    </a>
                                </div>
                            </div>
                        `;
                    })() :
                    `<video controls style="width: 100%; max-height: 400px; border-radius: 8px;">
                        <source src="${videoUrl}" type="video/mp4">
                        Your browser does not support the video tag.
                    </video>`
                }
            </div>
        </div>
    `;
    
    modal.className = 'video-modal';
    document.body.appendChild(modal);

    // Close modal on background click
    modal.addEventListener('click', function(e) {
        if (e.target === modal) {
            modal.remove();
        }
    });
}

// Event listeners
document.addEventListener('DOMContentLoaded', function() {
    loadDestinations();
    
    // Search functionality
    document.getElementById('searchInput').addEventListener('input', function() {
        currentPage = 1; // Reset to first page when searching
        displayDestinations(allPlaces);
    });
    
    // Category filter buttons
    document.querySelectorAll('.category-btn').forEach(btn => {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            currentCategory = this.getAttribute('data-category');
            currentPage = 1; // Reset to first page when filtering
            displayDestinations(allPlaces);
        });
    });
});

function toggleMobileMenu() {
    const nav = document.getElementById('mobile-nav');
    nav.classList.toggle('active');
}
</script>

<style>
.category-btn {
    padding: 12px 24px;
    background: white;
    border: 2px solid var(--primary-color);
    border-radius: 25px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
    color: #000;
