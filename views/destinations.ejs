<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Destinations - Ethiopia 361°</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="css/ai-chat.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"></script>
</head>

<body>

<header>
<h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>

<div class="mobile-header">
    <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
        <span></span>
        <span></span>
        <span></span>
    </button>
</div>

<nav class="desktop-nav">
<a href="/">Home</a>
<a href="/destinations" class="active">Destinations</a>
<a href="/culture">Culture</a>
<a href="/guide">Travel Guide</a>
<a href="/gallery">Gallery</a>
<a href="/blog">Blog</a>
<a href="/contact">Contact</a>
</nav>

<nav class="mobile-nav" id="mobile-nav">
<a href="/">Home</a>
<a href="/destinations" class="active">Destinations</a>
<a href="/culture">Culture</a>
<a href="/guide">Travel Guide</a>
<a href="/gallery">Gallery</a>
<a href="/blog">Blog</a>
<a href="/contact">Contact</a>
</nav>

<select id="language" onchange="changeLanguage()">
<option value="en">English</option>
<option value="am">አማርኛ</option>
</select>

</header>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support the video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Explore Ethiopia's Destinations" data-am="የኢትዮጵያን መዳረሻዎችን ያግኙ">Explore Ethiopia's Destinations</h2>
        <p data-en="Discover amazing places, ancient history, and breathtaking landscapes" data-am="የሚያምር ቦታዎች፣ ጥንታዊ ታሪክ እና የሚያስደንቅ መልክዮችን ያግኙ">Discover amazing places, ancient history, and breathtaking landscapes</p>
    </div>
</section>

<section class="places-grid">
<h2 data-en="All Destinations" data-am="ሁሉም መዳረሻዎች">All Destinations</h2>

<!-- Stats Bar -->
<div class="stats-bar">
    <div class="stat-item">
        <div class="stat-number" id="totalPlaces">0</div>
        <div class="stat-label" data-en="Total Places" data-am="ድምር ቦታዎች">Total Places</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="placesWithImages">0</div>
        <div class="stat-label" data-en="With Images" data-am="ከምስልክሎች ጋር">With Images</div>
    </div>
    <div class="stat-item">
        <div class="stat-number" id="placesWithVideos">0</div>
        <div class="stat-label" data-en="With Videos" data-am="ከቪዲዮዎች ጋር">With Videos</div>
    </div>
    <div class="stat-item">
        <div class="stat-number">361°</div>
        <div class="stat-label" data-en="Experience" data-am="ተሞክሮ">Experience</div>
    </div>
</div>

<div class="grid-container" id="destinationsContent">
    <!-- Places will be loaded here -->
</div>
</section>

<footer>
<p>© 2026 Ethiopia 361°</p>
</footer>

<script src="js/language.js"></script>
<script src="js/ai-chat.js"></script>
<script>
function toggleMobileMenu() {
    const mobileNav = document.getElementById('mobile-nav');
    const menuBtn = document.querySelector('.mobile-menu-btn');
    
    if (mobileNav.classList.contains('active')) {
        mobileNav.classList.remove('active');
        menuBtn.classList.remove('active');
    } else {
        mobileNav.classList.add('active');
        menuBtn.classList.add('active');
    }
}

async function loadDestinations() {
    try {
        const response = await fetch('/api/places');
        const places = await response.json();
        
        const container = document.getElementById('destinationsContent');
        
        // Update stats
        document.getElementById('totalPlaces').textContent = places.length;
        document.getElementById('placesWithImages').textContent = places.filter(p => p.image_url).length;
        document.getElementById('placesWithVideos').textContent = places.filter(p => p.video_url).length;
        
        if (places.length === 0) {
            container.innerHTML = `
                <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                    <i class="fas fa-map-marked-alt" style="font-size: 4rem; color: var(--primary-color); margin-bottom: 1rem;"></i>
                    <h3 data-en="No Destinations Yet" data-am="መዳረሻዎች ገና የሉም">No Destinations Yet</h3>
                    <p data-en="Amazing Ethiopian destinations will be added soon!" data-am="የሚያምር የኢትዮጵያ መዳረሻዎች በቅርብ ይታከላሉ!">Amazing Ethiopian destinations will be added soon!</p>
                </div>
            `;
            return;
        }
        
        container.innerHTML = places.map(place => `
            <div class="card">
                ${place.image_url ? `
                    ${place.image_url.startsWith('/uploads/') 
                        ? `<img src="${place.image_url}" alt="${place.name}" class="place-img">`
                        : `<img src="/img/${place.image_url}" alt="${place.name}" class="place-img">`
                    }
                ` : `
                    <div style="height: 200px; background: linear-gradient(45deg, var(--primary-color), var(--secondary-color)); display: flex; align-items: center; justify-content: center; margin: -20px -20px 15px -20px; border-radius: 8px 8px 0 0;">
                        <i class="fas fa-image" style="font-size: 3rem; color: white;"></i>
                    </div>
                `}
                <h3>${place.name}</h3>
                <p class="place-description">
                    <span class="short-text">${place.description ? place.description.substring(0, 100) + '...' : 'Discover this amazing destination in Ethiopia'}</span>
                    <span class="full-text" style="display: none;">${place.description || 'Discover this amazing destination in Ethiopia'}</span>
                </p>
                <div class="card-actions">
                    <button class="btn-read-more" onclick="toggleReadMore(this)" data-en="Read More" data-am="ተጨማሪ ያንብቡ">Read More</button>
                    <a href="/place/${place.id}" class="btn-view-details" data-en="View Details" data-am="ዝርዝሮችን ይመልከቱ">View Details</a>
                    ${place.video_url ? `
                        <button class="btn-read-more" onclick="showVideo('${place.video_url}', '${place.name}')" style="background-color: var(--secondary-color); color: var(--text-dark);">
                            <i class="fas fa-play"></i> <span data-en="Watch Video" data-am="ቪዲዮውን ይመልከቱ">Watch Video</span>
                        </button>
                    ` : ''}
                </div>
            </div>
        `).join('');
        
    } catch (error) {
        console.error('Error loading destinations:', error);
        document.getElementById('destinationsContent').innerHTML = `
            <div class="card" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 4rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later." data-am="እባክዎን ቆይተው ይሞክሩ።">Please try again later.</p>
            </div>
        `;
    }
}

function showVideo(videoUrl, placeName) {
    if (videoUrl.startsWith('/uploads/')) {
        // For uploaded videos
        window.open(`/video-player?src=${encodeURIComponent(videoUrl)}&title=${encodeURIComponent(placeName)}`, '_blank', 'width=800,height=600');
    } else {
        // For YouTube/embedded videos
        window.open(videoUrl, '_blank');
    }
}

function toggleReadMore(button) {
    const card = button.closest('.card');
    const shortText = card.querySelector('.short-text');
    const fullText = card.querySelector('.full-text');
    
    if (fullText.style.display === 'none') {
        // Show full text
        shortText.style.display = 'none';
        fullText.style.display = 'inline';
        button.textContent = button.getAttribute('data-am') === 'ተጨማሪ ያንብቡ' ? 'ቀንል' : 'Show Less';
        button.classList.add('expanded');
    } else {
        // Show short text
        shortText.style.display = 'inline';
        fullText.style.display = 'none';
        button.textContent = button.getAttribute('data-en') === 'Read More' ? 'Read More' : 'ተጨማሪ ያንብቡ';
        button.classList.remove('expanded');
    }
}

// Load destinations when page loads
document.addEventListener('DOMContentLoaded', loadDestinations);
</script>

</body>
</html>