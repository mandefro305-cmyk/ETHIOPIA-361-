<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Explore Ethiopia by Category - Ethiopia 361°</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/ai-chat.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        .categories-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem;
        }
        
        .category-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }
        
        .category-card {
            background: white;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 8px 25px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            cursor: pointer;
        }
        
        .category-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
        }
        
        .category-header {
            padding: 2rem;
            text-align: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        
        .category-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .category-title {
            font-size: 1.5rem;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }
        
        .category-description {
            opacity: 0.9;
            font-size: 0.9rem;
        }
        
        .category-places {
            padding: 1.5rem;
        }
        
        .place-item {
            display: flex;
            align-items: center;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 0.5rem;
            background: #f8f9fa;
            transition: all 0.3s ease;
        }
        
        .place-item:hover {
            background: #e9ecef;
            transform: translateX(5px);
        }
        
        .place-image {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            object-fit: cover;
            margin-right: 1rem;
        }
        
        .place-info {
            flex: 1;
        }
        
        .place-name {
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 0.25rem;
        }
        
        .place-description {
            font-size: 0.85rem;
            color: #6c757d;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        
        .travel-guide-btn {
            background: #28a745;
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 5px;
            font-size: 0.8rem;
            cursor: pointer;
            transition: background 0.3s ease;
        }
        
        .travel-guide-btn:hover {
            background: #218838;
        }
        
        .page-header {
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .page-title {
            font-size: 3rem;
            color: #2c3e50;
            margin-bottom: 1rem;
        }
        
        .page-subtitle {
            font-size: 1.2rem;
            color: #6c757d;
        }
        
        .back-nav {
            margin-bottom: 2rem;
        }
        
        .back-nav a {
            color: #667eea;
            text-decoration: none;
            font-weight: bold;
        }
        
        .back-nav a:hover {
            text-decoration: underline;
        }
    </style>
<link rel="apple-touch-icon" sizes="180x180" href="/img/apple-touch-icon.png">
<link rel="icon" type="image/png" sizes="32x32" href="/img/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/img/favicon-16x16.png">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-logo">
                <a href="/">Ethiopia 361°</a>
            </div>
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/categories" class="active">Categories</a></li>
                <li><a href="/places">All Places</a></li>
                <li><a href="/contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <div class="categories-container">
        <div class="back-nav">
            <a href="/"><i class="fas fa-arrow-left"></i> Back to Home</a>
        </div>

        <div class="page-header">
            <h1 class="page-title">Explore Ethiopia by Category</h1>
            <p class="page-subtitle">Discover the diverse wonders of Ethiopia through our curated categories</p>
        </div>

        <div class="category-grid">
            <!-- Historical & Cultural Sites -->
            <div class="category-card" onclick="filterByCategory('Historical & Cultural Sites')">
                <div class="category-header">
                    <div class="category-icon">🏛️</div>
                    <div class="category-title">Historical & Cultural Sites</div>
                    <div class="category-description">Ancient churches, archaeological wonders, and cultural heritage</div>
                </div>
                <div class="category-places" id="historical-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>

            <!-- Nature & Mountains -->
            <div class="category-card" onclick="filterByCategory('Nature & Mountains')">
                <div class="category-header" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);">
                    <div class="category-icon">🌄</div>
                    <div class="category-title">Nature & Mountains</div>
                    <div class="category-description">Majestic peaks, national parks, and natural landscapes</div>
                </div>
                <div class="category-places" id="nature-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>

            <!-- Unique & Adventure Destinations -->
            <div class="category-card" onclick="filterByCategory('Unique & Adventure Destinations')">
                <div class="category-header" style="background: linear-gradient(135deg, #fc4a1a 0%, #f7b733 100%);">
                    <div class="category-icon">🌋</div>
                    <div class="category-title">Unique & Adventure Destinations</div>
                    <div class="category-description">Extraordinary experiences and thrilling adventures</div>
                </div>
                <div class="category-places" id="adventure-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>

            <!-- Lakes & Water Attractions -->
            <div class="category-card" onclick="filterByCategory('Lakes & Water Attractions')">
                <div class="category-header" style="background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);">
                    <div class="category-icon">🌊</div>
                    <div class="category-title">Lakes & Water Attractions</div>
                    <div class="category-description">Beautiful lakes, waterfalls, and aquatic wonders</div>
                </div>
                <div class="category-places" id="water-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>

            <!-- Cities & Urban Tourism -->
            <div class="category-card" onclick="filterByCategory('Cities & Urban Tourism')">
                <div class="category-header" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="category-icon">🏙️</div>
                    <div class="category-title">Cities & Urban Tourism</div>
                    <div class="category-description">Modern cities, markets, and urban experiences</div>
                </div>
                <div class="category-places" id="cities-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>

            <!-- Relaxation & Resort Areas -->
            <div class="category-card" onclick="filterByCategory('Relaxation & Resort Areas')">
                <div class="category-header" style="background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);">
                    <div class="category-icon">🌿</div>
                    <div class="category-title">Relaxation & Resort Areas</div>
                    <div class="category-description">Peaceful retreats, spas, and relaxation spots</div>
                </div>
                <div class="category-places" id="relaxation-places">
                    <!-- Places will be loaded here -->
                </div>
            </div>
        </div>
    </div>

    <!-- Travel Guide Modal -->
    <div id="travelGuideModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="position: relative; background: white; margin: 5% auto; padding: 2rem; width: 90%; max-width: 800px; max-height: 80vh; overflow-y: auto; border-radius: 15px;">
            <button onclick="closeTravelGuide()" style="position: absolute; top: 1rem; right: 1rem; background: none; border: none; font-size: 2rem; cursor: pointer;">×</button>
            <div id="travelGuideContent">
                <!-- Travel guide content will be loaded here -->
            </div>
        </div>
    </div>

    <script>
        // Load places by category
        async function loadPlacesByCategory() {
            try {
                const response = await fetch('/api/places/by-category');
                const data = await response.json();
                
                // Populate each category with places
                Object.keys(data).forEach(category => {
                    const categoryId = category.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/&/g, '').replace(/\s+/g, '-');
                    const container = document.getElementById(categoryId + '-places');
                    
                    if (container && data[category].length > 0) {
                        container.innerHTML = data[category].map(place => `
                            <div class="place-item">
                                <img src="${place.image_url ? (place.image_url.startsWith('http') || place.image_url.startsWith('/') ? place.image_url : '/img/' + place.image_url) : '/img/placeholder.jpg'}" alt="${place.name}" class="place-image" onerror="this.onerror=null; this.src='/img/placeholder.jpg';">
                                <div class="place-info">
                                    <div class="place-name">${place.name}</div>
                                    <div class="place-description">${place.description}</div>
                                </div>
                                <button class="travel-guide-btn" onclick="showTravelGuide('${place._id}')">
                                    <i class="fas fa-map-signs"></i> Travel Guide
                                </button>
                            </div>
                        `).join('');
                    } else if (container) {
                        container.innerHTML = '<p style="text-align: center; color: #6c757d;">No places in this category yet.</p>';
                    }
                });
            } catch (error) {
                console.error('Error loading places:', error);
            }
        }

        // Filter by category
        function filterByCategory(category) {
            window.location.href = `/places?category=${encodeURIComponent(category)}`;
        }

        // Show travel guide
        async function showTravelGuide(placeId) {
            try {
                const response = await fetch(`/api/places/${placeId}/travel-guide`);
                const place = await response.json();
                
                const content = `
                    <h2>${place.category_icon} ${place.name}</h2>
                    <p><strong>Category:</strong> ${place.category}</p>
                    <p><strong>Description:</strong> ${place.description}</p>
                    
                    <h3><i class="fas fa-map-signs"></i> Travel Guide</h3>
                    
                    ${place.travel_guide.best_time_to_visit ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-calendar-alt"></i> Best Time to Visit:</strong>
                            <p>${place.travel_guide.best_time_to_visit}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.how_to_get_there ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-route"></i> How to Get There:</strong>
                            <p>${place.travel_guide.how_to_get_there}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.what_to_bring ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-backpack"></i> What to Bring:</strong>
                            <p>${place.travel_guide.what_to_bring}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.local_tips ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-lightbulb"></i> Local Tips:</strong>
                            <p>${place.travel_guide.local_tips}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.entrance_fees ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-ticket-alt"></i> Entrance Fees:</strong>
                            <p>${place.travel_guide.entrance_fees}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.opening_hours ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-clock"></i> Opening Hours:</strong>
                            <p>${place.travel_guide.opening_hours}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.accommodation ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-bed"></i> Accommodation:</strong>
                            <p>${place.travel_guide.accommodation}</p>
                        </div>
                    ` : ''}
                    
                    ${place.travel_guide.nearby_attractions ? `
                        <div style="margin-bottom: 1rem;">
                            <strong><i class="fas fa-map-marked"></i> Nearby Attractions:</strong>
                            <p>${place.travel_guide.nearby_attractions}</p>
                        </div>
                    ` : ''}
                `;
                
                document.getElementById('travelGuideContent').innerHTML = content;
                document.getElementById('travelGuideModal').style.display = 'block';
            } catch (error) {
                console.error('Error loading travel guide:', error);
            }
        }

        // Close travel guide
        function closeTravelGuide() {
            document.getElementById('travelGuideModal').style.display = 'none';
        }

        // Load places when page loads
        document.addEventListener('DOMContentLoaded', loadPlacesByCategory);
        
        // Close modal when clicking outside
        window.onclick = function(event) {
            const modal = document.getElementById('travelGuideModal');
            if (event.target == modal) {
                modal.style.display = 'none';
            }
        }
    </script>
<script src="/js/ai-chat.js"></script>
</body>
</html>
