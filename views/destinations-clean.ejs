<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Destinations - Ethiopia 361°</title>
    
    <!-- Modern CSS -->
    <link rel="stylesheet" href="/css/modern-style.css">
    <link rel="stylesheet" href="/css/ai-chat.css">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>

<%- include('partials/header', { currentPage: 'destinations' }) %>

<!-- ===== PAGE HERO ===== -->
<section class="page-hero">
    <div class="page-hero-overlay"></div>
    <div class="page-hero-content">
        <h1 data-en="Discover Ethiopia's Destinations" data-am="የኢትዮጵያን መዳረሻዎች ያግኙ">Discover Ethiopia's Destinations</h1>
        <p data-en="Explore ancient wonders, breathtaking landscapes, and vibrant cultures across the Land of Origins" data-am="በመነጽዐ ሀገር ውስጥ ያሉትን ቅዱሳን ድንቅ፣ ያማቅ መልክያዎች እና የበለጠ ባህሎች ይመልከቱ">
            Explore ancient wonders, breathtaking landscapes, and vibrant cultures across the Land of Origins
        </p>
    </div>
</section>

<!-- ===== DESTINATIONS SECTION ===== -->
<section class="destinations">
    <div class="container">
        <!-- Category Filters -->
        <div class="category-filters">
            <button class="filter-btn active" data-category="all">
                <i class="fas fa-globe"></i>
                <span data-en="All Places" data-am="ሁሉም ቦታዎች">All Places</span>
            </button>
            <button class="filter-btn" data-category="Historical & Cultural Sites">
                <i class="fas fa-landmark"></i>
                <span data-en="Historical" data-am="ታሪካዊ">Historical</span>
            </button>
            <button class="filter-btn" data-category="Nature & Mountains">
                <i class="fas fa-mountain"></i>
                <span data-en="Nature" data-am="ተፈጥቯዊ">Nature</span>
            </button>
            <button class="filter-btn" data-category="Lakes & Water Attractions">
                <i class="fas fa-water"></i>
                <span data-en="Lakes" data-am="ሀይቆች">Lakes</span>
            </button>
            <button class="filter-btn" data-category="Unique & Adventure Destinations">
                <i class="fas fa-compass"></i>
                <span data-en="Adventure" data-am="ተሳታፊ">Adventure</span>
            </button>
            <button class="filter-btn" data-category="Cities & Urban Tourism">
                <i class="fas fa-city"></i>
                <span data-en="Cities" data-am="ከተሞች">Cities</span>
            </button>
        </div>

        <!-- Places Grid -->
        <div class="places-grid" id="destinationsContent">
            <!-- Loading spinner -->
            <div id="destinationsLoader" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <div style="display: inline-block; width: 50px; height: 50px; border: 4px solid #e0e0e0; border-top-color: var(--primary-600); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
                <p style="margin-top: 1rem; color: #888;" data-en="Loading destinations..." data-am="መዳረሻዎችን በመጫን ላይ...">Loading destinations...</p>
            </div>
            <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
        </div>

        <!-- No Results Message -->
        <div class="no-results" id="no-results" style="display: none;">
            <i class="fas fa-search"></i>
            <h3 data-en="No places found" data-am="ምንም ቦታዎች አልተገኙም">No places found</h3>
            <p data-en="Try selecting a different category" data-am="የተለየ ምድብ ይሞክሩ">Try selecting a different category</p>
        </div>
    </div>
</section>

<script src="/js/language.js"></script>
<script src="/js/common.js"></script>
<script src="/js/ai-chat.js"></script>
<script>
let allPlaces = [];
let currentCategory = 'all';

// Load destinations from database
async function loadDestinations() {
    try {
        const response = await fetch('/api/places');
        const places = await response.json();
        
        console.log('Loaded places:', places.length);
        
        allPlaces = places;
        
        // Remove loader
        const loader = document.getElementById('destinationsLoader');
        if (loader) loader.remove();
        
        // Display using modern premium cards
        displayDestinations(allPlaces);
        
        // Setup category filters
        setupCategoryFilters();
        
    } catch (error) {
        console.error('Error loading destinations:', error);
        document.getElementById('destinationsContent').innerHTML = `
            <div class="no-results" style="grid-column: 1 / -1;">
                <i class="fas fa-exclamation-triangle"></i>
                <h3 data-en="Unable to Load Destinations" data-am="መዳረሻዎችን መጫን አልተቻለሁ">Unable to Load Destinations</h3>
                <p data-en="Please try again later" data-am="እባኮላ በኋላ ይሞክሉ">Please try again later</p>
            </div>
        `;
    }
}

// Display destinations with modern premium cards
function displayDestinations(places) {
    const container = document.getElementById('destinationsContent');
    const currentCategory = document.querySelector('.filter-btn.active')?.getAttribute('data-category') || 'all';
    
    // Filter places by category
    let filteredPlaces = places.filter(place => {
        if (currentCategory === 'all') return true;
        return place.category === currentCategory;
    });

    if (filteredPlaces.length === 0) {
        container.innerHTML = `
            <div class="no-results" style="grid-column: 1 / -1;">
                <i class="fas fa-search"></i>
                <h3 data-en="No places found" data-am="ምንም ቦታዎች አልተገኙም">No places found</h3>
                <p data-en="Try selecting a different category" data-am="የተለየ ምድብ ይሞክሩ">Try selecting a different category</p>
            </div>
        `;
        document.getElementById('no-results').style.display = 'block';
        return;
    }
    
    document.getElementById('no-results').style.display = 'none';
    
    // Use the modern premium card generation
    generateDestinationCards(filteredPlaces, 'destinationsContent');
}

// Setup category filter event listeners
function setupCategoryFilters() {
    const filterButtons = document.querySelectorAll('.filter-btn');
    
    filterButtons.forEach(button => {
        button.addEventListener('click', function() {
            // Remove active class from all buttons
            filterButtons.forEach(btn => btn.classList.remove('active'));
            // Add active class to clicked button
            this.classList.add('active');
            
            // Re-display destinations with new filter
            displayDestinations(allPlaces);
        });
    });
}

// Load destinations when page loads
document.addEventListener('DOMContentLoaded', loadDestinations);
</script>

<%- include('partials/footer') %>

</body>
</html>
