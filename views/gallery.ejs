<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Gallery - Ethiopia 361°</title>
<link rel="stylesheet" href="css/style.css">
<link rel="stylesheet" href="css/ai-chat.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
<link rel="icon" type="image/jpeg" href="/img/favicon-image.jpg">
</head>

<body>

<header>
    <h1 data-en="Ethiopia 361°" data-am="ኢትዮጵያ 361°">Ethiopia 361°</h1>
    <nav class="desktop-nav">
        <a href="/" data-en="Home" data-am="ቤት">Home</a>
        <a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
        <a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
        <a href="/gallery" class="active" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
        <a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
        <a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
        <a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
    </nav>
    <div class="header-right">
        <div class="theme-toggle" onclick="toggleDarkMode()" title="Toggle Dark Mode"></div>
        <select id="language" onchange="changeLanguage()">
            <option value="en">English</option>
            <option value="am">አማርኛ</option>
        </select>
        <button class="mobile-menu-btn" onclick="toggleMobileMenu()">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>
<nav class="mobile-nav" id="mobile-nav">
    <a href="/" data-en="Home" data-am="ቤት">Home</a>
    <a href="/destinations" data-en="Destinations" data-am="መዳረሻዎች">Destinations</a>
    <a href="/guide" data-en="Travel Guide" data-am="የጉዞ መርህቆ">Travel Guide</a>
    <a href="/gallery" class="active" data-en="Gallery" data-am="ጋለሪ">Gallery</a>
    <a href="/blog" data-en="Blog" data-am="ብሎግ">Blog</a>
    <a href="/contact" data-en="Contact" data-am="ይድረሹ">Contact</a>
    <a href="/admin" class="nav-cta" data-en="Admin Panel" data-am="አስተባባሪ">Admin Panel</a>
</nav>

<section class="hero">
    <video autoplay muted loop playsinline class="hero-video">
        <source src="/videos/hero-background.mp4" type="video/mp4">
        Your browser does not support video tag.
    </video>
    <div class="hero-overlay">
        <h2 data-en="Ethiopia in Pictures" data-am="ኢትዮጵያ በምስልክዮች">Ethiopia in Pictures</h2>
        <p data-en="Explore the beauty of Ethiopia through our collection" data-am="የኢትዮጵያን ውበት በስብሰታችን ያስሱ">Explore the beauty of Ethiopia through our collection</p>
    </div>
</section>

<!-- Gallery Filter Section -->
<section class="gallery-filters">
    <h2 data-en="Photo Gallery" data-am="የፎቶ ጋለሪ">Photo Gallery</h2>
    <p class="gallery-subtitle" data-en="Click on a destination to explore its photos" data-am="ፎቶዎቹን ለማየት መዳረሻ ላይ ጠቅ ያድርጉ">Click on a destination to explore its photos</p>
    <div class="filter-buttons" id="filterButtons">
        <button class="filter-btn active" data-filter="all" data-en="All" data-am="ሁሉን">All</button>
        <button class="filter-btn" data-filter="historical" data-en="Historical" data-am="ታሪክ">Historical</button>
        <button class="filter-btn" data-filter="nature" data-en="Nature" data-am="ተፈሪ">Nature</button>
        <button class="filter-btn" data-filter="lakes" data-en="Lakes" data-am="ሀይቆች">Lakes</button>
        <button class="filter-btn" data-filter="cities" data-en="Cities" data-am="ከተማዎች">Cities</button>
        <button class="filter-btn" data-filter="adventure" data-en="Adventure" data-am="የጉዞ">Adventure</button>
    </div>
</section>

<!-- Place Cards Grid -->
<section class="gallery-container">
    <div class="gallery-places-grid" id="galleryContent">
        <div id="galleryLoader" style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
            <div style="display: inline-block; width: 50px; height: 50px; border: 4px solid #e0e0e0; border-top-color: var(--primary-color); border-radius: 50%; animation: spin 0.8s linear infinite;"></div>
            <p style="margin-top: 1rem; color: #888;" data-en="Loading gallery..." data-am="ጋለሪን በመጫን ላይ...">Loading gallery...</p>
        </div>
        <style>@keyframes spin { to { transform: rotate(360deg); } }</style>
    </div>
</section>

<!-- Photo Viewer Modal -->
<div id="photoViewer" class="photo-viewer">
    <div class="photo-viewer-header">
        <h3 id="viewerTitle"></h3>
        <button class="viewer-close" onclick="closeViewer()"><i class="fas fa-times"></i></button>
    </div>
    <div class="photo-viewer-body">
        <button class="viewer-nav viewer-prev" onclick="navigatePhoto(-1)"><i class="fas fa-chevron-left"></i></button>
        <div class="photo-viewer-main">
            <img id="viewerImage" src="" alt="" loading="lazy">
        </div>
        <button class="viewer-nav viewer-next" onclick="navigatePhoto(1)"><i class="fas fa-chevron-right"></i></button>
    </div>
    <div class="photo-viewer-thumbs" id="viewerThumbs"></div>
    <div class="photo-viewer-counter" id="viewerCounter"></div>
</div>
<div id="photoViewerOverlay" class="photo-viewer-overlay" onclick="closeViewer()"></div>

<script>
let allPlaces = [];
let currentFilter = 'all';
let viewerImages = [];
let viewerIndex = 0;

async function loadGallery() {
    try {
        const response = await fetch('/api/places');
        allPlaces = await response.json();
        console.log('=== GALLERY DEBUG ===');
        console.log('Total places from API:', allPlaces.length);
        allPlaces.forEach(function(p) {
            console.log('Place:', p.name, '| image_url:', p.image_url, '| gallery_images:', p.gallery_images);
        });
        console.log('=== END DEBUG ===');
        const loader = document.getElementById('galleryLoader');
        if (loader) loader.remove();
        displayPlaceCards(allPlaces);
    } catch (error) {
        console.error('Error loading gallery:', error);
        document.getElementById('galleryContent').innerHTML = `
            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-exclamation-triangle" style="font-size: 3rem; color: #e74c3c; margin-bottom: 1rem;"></i>
                <h3 data-en="Unable to Load Gallery" data-am="ጋለሪን መጫን አልተቻለሁ">Unable to Load Gallery</h3>
                <p style="color:#888;">${error.message}</p>
            </div>`;
    }
}

function getImageUrl(img) {
    if (!img) return null;
    if (img.startsWith('http') || img.startsWith('/uploads/')) return img;
    return '/img/' + img;
}

function getPlaceImages(place) {
    console.log('=== getPlaceImages for:', place.name, '===');
    console.log('Raw gallery_images:', place.gallery_images);
    console.log('Raw image_url:', place.image_url);
    
    var images = [];
    var seen = {};

    // gallery_images already includes the main image (added by server)
    if (place.gallery_images && place.gallery_images.length > 0) {
        var galleryImgs = [];
        if (typeof place.gallery_images === 'string') {
            try { 
                galleryImgs = JSON.parse(place.gallery_images); 
                console.log('Parsed gallery_images from string:', galleryImgs);
            } catch (e) { 
                console.log('Failed to parse gallery_images as string:', e);
                galleryImgs = []; 
            }
        } else {
            galleryImgs = place.gallery_images;
            console.log('Using gallery_images as array:', galleryImgs);
        }
        galleryImgs.forEach(function(img) {
            var url = getImageUrl(img);
            console.log('Processing image:', img, '-> URL:', url);
            if (url && !seen[url]) {
                seen[url] = true;
                images.push(url);
                console.log('Added image to gallery:', url);
            } else if (!url) {
                console.log('Skipped null/undefined image');
            } else {
                console.log('Skipped duplicate image:', url);
            }
        });
    } else {
        console.log('No gallery_images found');
    }

    // If gallery_images was empty, use main image_url as fallback
    if (images.length === 0 && place.image_url) {
        var mainUrl = getImageUrl(place.image_url);
        console.log('Using main image_url as fallback:', place.image_url, '->', mainUrl);
        if (mainUrl) images.push(mainUrl);
    }

    console.log('Final images array:', images);
    console.log('=== END getPlaceImages ===');
    return images;
}

function getCategoryIcon(category) {
    const icons = {
        'Historical & Cultural Sites': '🏛️',
        'Nature & Mountains': '🌄',
        'Unique & Adventure Destinations': '🌋',
        'Lakes & Water Attractions': '🌊',
        'Cities & Urban Tourism': '🏙️',
        'Relaxation & Resort Areas': '🌿'
    };
    return icons[category] || '📍';
}

function displayPlaceCards(places) {
    const container = document.getElementById('galleryContent');
    console.log('Filter:', currentFilter, 'Total places:', places.length);
    console.log('Categories in data:', [...new Set(places.map(p => p.category))]);
    const filtered = places.filter(p => {
        if (currentFilter === 'all') return true;
        return p.category && p.category.toLowerCase() === currentFilter.toLowerCase();
    });

    if (filtered.length === 0) {
        container.innerHTML = `
            <div style="grid-column: 1 / -1; text-align: center; padding: 3rem;">
                <i class="fas fa-images" style="font-size: 3rem; color: #888; margin-bottom: 1rem;"></i>
                <h3 data-en="No Places Found" data-am="ምንም ቦታ አልተገኘም">No Places Found</h3>
            </div>`;
        return;
    }

    let html = '';
    filtered.forEach((place, idx) => {
        const images = getPlaceImages(place);
        const coverImg = images.length > 0 ? images[0] : '';
        const imgCount = images.length;
        html += `
            <div class="gallery-place-card" onclick="openViewer(${idx})">
                <div class="gallery-card-img">
                    <img src="${coverImg}" alt="${place.name}" loading="lazy">
                    <div class="gallery-card-badge">${getCategoryIcon(place.category)}</div>
                    <div class="gallery-card-count"><i class="fas fa-images"></i> ${imgCount}</div>
                </div>
                <div class="gallery-card-info">
                    <h3 data-en="${place.name}" data-am="${place.name_am || place.name}">${place.name}</h3>
                    <p class="gallery-card-cat">${place.category || 'Destination'}</p>
                </div>
            </div>`;
    });
    container.innerHTML = html;

    // Store filtered for viewer access
    window._filteredPlaces = filtered;
}

function openViewer(placeIdx) {
    var places = window._filteredPlaces;
    if (!places || !places[placeIdx]) { console.error('No place at index', placeIdx); return; }
    var place = places[placeIdx];
    viewerImages = getPlaceImages(place);
    viewerIndex = 0;
    console.log('Opening viewer for:', place.name, 'Images:', viewerImages.length, viewerImages);

    document.getElementById('viewerTitle').textContent = place.name;

    // Show/hide nav buttons based on image count
    var hasMultiple = viewerImages.length > 1;
    document.querySelector('.viewer-prev').style.display = hasMultiple ? '' : 'none';
    document.querySelector('.viewer-next').style.display = hasMultiple ? '' : 'none';

    updateViewer();
    buildThumbnails();

    document.getElementById('photoViewer').classList.add('active');
    document.getElementById('photoViewerOverlay').classList.add('active');
    document.body.style.overflow = 'hidden';
    initSwipe();
}

function closeViewer() {
    document.getElementById('photoViewer').classList.remove('active');
    document.getElementById('photoViewerOverlay').classList.remove('active');
    document.body.style.overflow = '';
}

function updateViewer() {
    var img = document.getElementById('viewerImage');
    var newSrc = viewerImages[viewerIndex];
    console.log('Showing image', viewerIndex + 1, 'of', viewerImages.length, ':', newSrc);
    img.src = newSrc;
    document.getElementById('viewerCounter').textContent = (viewerIndex + 1) + ' / ' + viewerImages.length;

    document.querySelectorAll('.viewer-thumb').forEach(function(t, i) {
        t.classList.toggle('active', i === viewerIndex);
    });
}

function buildThumbnails() {
    var container = document.getElementById('viewerThumbs');
    if (viewerImages.length <= 1) { container.innerHTML = ''; return; }
    container.innerHTML = viewerImages.map(function(src, i) {
        return '<img class="viewer-thumb ' + (i === 0 ? 'active' : '') + '" src="' + src + '" alt="Thumb ' + (i+1) + '" onclick="goToPhoto(' + i + ')">';
    }).join('');
}

function navigatePhoto(dir) {
    if (viewerImages.length <= 1) return;
    viewerIndex = (viewerIndex + dir + viewerImages.length) % viewerImages.length;
    updateViewer();
}

function goToPhoto(idx) {
    viewerIndex = idx;
    updateViewer();
}

// Swipe support for mobile
var touchStartX = 0;
var touchEndX = 0;
function initSwipe() {
    var body = document.querySelector('.photo-viewer-body');
    body.ontouchstart = function(e) { touchStartX = e.changedTouches[0].screenX; };
    body.ontouchend = function(e) {
        touchEndX = e.changedTouches[0].screenX;
        var diff = touchStartX - touchEndX;
        if (Math.abs(diff) > 50) {
            navigatePhoto(diff > 0 ? 1 : -1);
        }
    };
}

// Keyboard navigation
document.addEventListener('keydown', function(e) {
    const viewer = document.getElementById('photoViewer');
    if (!viewer.classList.contains('active')) return;
    if (e.key === 'ArrowLeft') navigatePhoto(-1);
    if (e.key === 'ArrowRight') navigatePhoto(1);
    if (e.key === 'Escape') closeViewer();
});

// Category mapping for filter buttons
const categoryMap = {
    'all': 'all',
    'historical': 'Historical & Cultural Sites',
    'nature': 'Nature & Mountains',
    'lakes': 'Lakes & Water Attractions',
    'cities': 'Cities & Urban Tourism',
    'adventure': 'Unique & Adventure Destinations'
};

document.addEventListener('DOMContentLoaded', function() {
    loadGallery();

    document.getElementById('filterButtons').addEventListener('click', function(e) {
        var btn = e.target.closest('.filter-btn');
        if (!btn) return;
        var key = btn.getAttribute('data-filter');
        document.querySelectorAll('.filter-btn').forEach(function(b) { b.classList.remove('active'); });
        btn.classList.add('active');
        currentFilter = categoryMap[key] || 'all';
        displayPlaceCards(allPlaces);
    });
});

function toggleMobileMenu() {
    const nav = document.getElementById('mobile-nav');
    const btn = document.querySelector('.mobile-menu-btn');
    nav.classList.toggle('active');
    if (btn) btn.classList.toggle('active');
}
</script>
<script src="/js/language.js"></script>
<script src="/js/ai-chat.js"></script>

<style>
/* Gallery Filters */
.gallery-filters {
    padding: 2rem 1.5rem 1rem;
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
}
.gallery-filters h2 {
    color: var(--primary-color);
    margin-bottom: 0.5rem;
    font-size: 2rem;
}
.gallery-subtitle {
    color: #666;
    margin-bottom: 1.5rem;
}
.filter-buttons {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: wrap;
}
.filter-btn {
    padding: 10px 20px;
    background: white;
    border: 2px solid var(--primary-color);
    border-radius: 25px;
    cursor: pointer;
    font-weight: 500;
    transition: all 0.3s ease;
    color: var(--primary-color);
    font-size: 0.9rem;
}
.filter-btn:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-2px);
}
.filter-btn.active {
    background: var(--primary-color);
    color: white;
}

/* Gallery Container */
.gallery-container {
    padding: 1.5rem;
    max-width: 1400px;
    margin: 0 auto;
}

/* Place Cards Grid */
.gallery-places-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
}

.gallery-place-card {
    border-radius: 16px;
    overflow: hidden;
    background: white;
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    cursor: pointer;
    transition: all 0.3s ease;
}
.gallery-place-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 35px rgba(0,0,0,0.15);
}
.gallery-card-img {
    position: relative;
    height: 220px;
    overflow: hidden;
}
.gallery-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
}
.gallery-place-card:hover .gallery-card-img img {
    transform: scale(1.08);
}
.gallery-card-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(8px);
    color: white;
    padding: 6px 10px;
    border-radius: 8px;
    font-size: 1.2rem;
}
.gallery-card-count {
    position: absolute;
    bottom: 12px;
    right: 12px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    color: white;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    gap: 6px;
}
.gallery-card-info {
    padding: 1rem 1.2rem;
}
.gallery-card-info h3 {
    color: var(--primary-color);
    font-size: 1.15rem;
    margin: 0 0 0.3rem;
}
.gallery-card-cat {
    color: #888;
    font-size: 0.85rem;
    margin: 0;
}

/* Photo Viewer Overlay */
.photo-viewer-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.85);
    z-index: 2000;
}
.photo-viewer-overlay.active {
    display: block;
}

/* Photo Viewer Panel */
.photo-viewer {
    display: none;
    position: fixed;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    max-width: 900px;
    max-height: 90vh;
    background: #1a1a1a;
    border-radius: 16px;
    z-index: 2001;
    overflow: hidden;
    flex-direction: column;
}
.photo-viewer.active {
    display: flex;
}

.photo-viewer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    background: rgba(0,77,64,0.95);
    color: white;
}
.photo-viewer-header h3 {
    margin: 0;
    font-size: 1.2rem;
}
.viewer-close {
    background: rgba(255,255,255,0.15);
    border: none;
    color: white;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
}
.viewer-close:hover {
    background: rgba(255,255,255,0.3);
}

.photo-viewer-body {
    display: flex;
    align-items: center;
    position: relative;
    flex: 1;
    min-height: 0;
    background: #111;
}

.photo-viewer-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    min-height: 300px;
    max-height: 55vh;
}
.photo-viewer-main img {
    max-width: 100%;
    max-height: 55vh;
    object-fit: contain;
    border-radius: 8px;
}

.viewer-nav {
    background: rgba(255,255,255,0.1);
    border: none;
    color: white;
    font-size: 1.5rem;
    padding: 1rem 0.8rem;
    cursor: pointer;
    transition: background 0.2s;
    flex-shrink: 0;
}
.viewer-nav:hover {
    background: rgba(255,255,255,0.25);
}

.photo-viewer-thumbs {
    display: flex;
    gap: 8px;
    padding: 0.75rem 1rem;
    overflow-x: auto;
    background: #1a1a1a;
    justify-content: center;
    flex-wrap: nowrap;
}
.viewer-thumb {
    width: 60px;
    height: 45px;
    object-fit: cover;
    border-radius: 6px;
    cursor: pointer;
    opacity: 0.5;
    transition: all 0.2s ease;
    flex-shrink: 0;
    border: 2px solid transparent;
}
.viewer-thumb:hover {
    opacity: 0.8;
}
.viewer-thumb.active {
    opacity: 1;
    border-color: var(--primary-color);
}

.photo-viewer-counter {
    text-align: center;
    color: #aaa;
    font-size: 0.85rem;
    padding: 0.5rem 0 0.75rem;
    background: #1a1a1a;
}

/* Responsive */
@media (max-width: 768px) {
    .gallery-places-grid {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
        gap: 1rem;
    }
    .gallery-card-img {
        height: 150px;
    }
    .gallery-card-info {
        padding: 0.75rem;
    }
    .gallery-card-info h3 {
        font-size: 1rem;
    }
    .gallery-filters h2 {
        font-size: 1.4rem;
    }
    .filter-btn {
        padding: 8px 14px;
        font-size: 0.8rem;
    }
    .photo-viewer {
        width: 96%;
        max-height: 95vh;
    }
    .photo-viewer-main {
        min-height: 200px;
        max-height: 45vh;
    }
    .photo-viewer-main img {
        max-height: 45vh;
    }
    .viewer-nav {
        padding: 1rem 0.75rem;
        font-size: 1.4rem;
        min-width: 44px;
        min-height: 44px;
    }
    .viewer-thumb {
        width: 45px;
        height: 35px;
    }
}
@media (max-width: 400px) {
    .gallery-places-grid {
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }
    .gallery-card-img {
        height: 120px;
    }
    .gallery-card-badge {
        padding: 4px 6px;
        font-size: 0.9rem;
    }
    .gallery-card-count {
        padding: 3px 8px;
        font-size: 0.75rem;
    }
}
</style>

</body>
</html>