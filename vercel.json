{
  "version": 2,
  "builds": [
    {
      "src": "server-mongodb.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server-mongodb.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
